<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <OutputType>WinExe</OutputType>
    <RootNamespace>Shell.UI</RootNamespace>
    <AssemblyName>АРМ Формирование НДТМ</AssemblyName>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <NoWarn>$(NoWarn);SYSLIB0011;WFO1000</NoWarn>
    <StartupObject>Shell.UI.Program</StartupObject>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <PlatformTarget>x86</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <Deterministic>false</Deterministic>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <PlatformTarget>x86</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <Deterministic>false</Deterministic>
  </PropertyGroup>

  <ItemGroup>
    <!-- Exclude Examples from build (they are example plugins, not part of main app) -->
    <Compile Remove="Examples\**\*.cs" />
    <EmbeddedResource Remove="Examples\**\*.resx" />
    <!-- Exclude auto-generated Resources.cs to prevent duplicate class definition -->
    <Compile Remove="Shell\UI\Properties\Resources.cs" />
  </ItemGroup>

  <ItemGroup>
    <!-- ProjectReference to ATToolbox library -->
    <ProjectReference Include="..\Toolbox\ATToolbox\ATToolbox.csproj">
      <Private>true</Private>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <!-- NuGet package references for .NET 10 compatibility -->
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="10.0.5" />
    <PackageReference Include="System.Drawing.Common" Version="10.0.5" />
    <PackageReference Include="System.Resources.Extensions" Version="10.0.5" />
    <PackageReference Include="Microsoft.Windows.Compatibility" Version="10.0.5" />
  </ItemGroup>

  <ItemGroup>
    <!-- External DLL references from lib directory and root -->
    <Reference Include="DevExpress.BonusSkins.v9.2">
