      <Definition>
CREATE VIEW [dbo].[ci_OrganizationView]
AS
SELECT     dbo.ci_Organization.ID, dbo.ci_OrganizationForm.Name AS Form, dbo.ci_Organization.Name, dbo.ci_Organization.NPR,
                      dbo.ci_Organization.Fax, dbo.ci_GetInitials(Secretary.Name, Secretary.Patronimic, Secretary.Surname) AS Secretary,
                      dbo.ci_GetInitials(ContactPerson.Name, ContactPerson.Patronimic, ContactPerson.Surname) AS ContactPerson, dbo.geo_AddressView.PostalCode,
                      dbo.geo_AddressView.RoadType, dbo.geo_AddressView.RoadName, dbo.geo_AddressView.HouseNumber, dbo.geo_AddressView.HouseIndex,
                      dbo.geo_AddressView.Litera
FROM         dbo.ci_Organization LEFT OUTER JOIN
                      dbo.geo_AddressView ON dbo.ci_Organization.AddressID = dbo.geo_AddressView.ID LEFT OUTER JOIN
                      dbo.ci_OrganizationForm ON dbo.ci_OrganizationForm.ID = dbo.ci_Organization.FormID LEFT OUTER JOIN
                      dbo.ci_Man AS Secretary ON Secretary.ID = dbo.ci_Organization.SecretaryID LEFT OUTER JOIN
                      dbo.ci_Man AS ContactPerson ON ContactPerson.ID = dbo.ci_Organization.ContactPersonID
</Definition>
    </ViewMould>
