      <Definition>
CREATE VIEW [dbo].[ln_LineRouteView]
AS
SELECT
	dbo.ln_LineRoute.ID,
	dbo.ln_Line.TransportType,
	dbo.ln_Line.Number,
	dbo.ln_LineRouteType.Name AS Type,
	dbo.ln_Direction.Name AS Direction,
	dbo.ln_LineRoute.IsActive,
	dbo.ln_LineRoute.StartDate,
	dbo.ln_LineRoute.EndDate,
	dbo.ln_LineRoute.[Length],
	dbo.ln_GetLineRouteStopPointCount(dbo.ln_LineRoute.ID)  AS StopPointCount,
	dbo.ln_GetLineRoutePathLength(dbo.ln_LineRoute.ID) AS RoadCount,
	dbo.ln_LineRoute.MeasureDate,
	dbo.ln_LineRoute.[WorkLoad],
	dbo.ln_LineRoute.Board,
	dbo.ln_LineRoute.Alight
FROM
	dbo.ln_LineRoute
INNER JOIN
	dbo.ln_Direction ON dbo.ln_LineRoute.DirectionID = dbo.ln_Direction.ID
INNER JOIN
	dbo.ln_LineRouteType ON dbo.ln_LineRoute.TypeID = dbo.ln_LineRouteType.ID
INNER JOIN
	dbo.ln_Line ON dbo.ln_LineRoute.LineID = dbo.ln_Line.ID
</Definition>
    </ViewMould>
    <ViewMould Name="ln_LineView" MappingName="LineView" CheckSum="204229067" Schema="dbo">
      <Columns>
        <ColumnMould Name="ID" MappingName="ID" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
