    <ProcedureMould Name="ln_GetLinesForStopPoint" MappingName="GetLinesForStopPoint" CheckSum="714759816" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[ln_GetLinesForStopPoint]
(
	@stopPointID int
)
AS
BEGIN
	SELECT *
	FROM dbo.ln_LineView
	WHERE dbo.ln_LineView.ID IN
	(
	SELECT dbo.ln_Line.ID FROM
		dbo.ln_Line
	INNER JOIN ln_LineRoute
	    ON ln_LineRoute.LineID = ln_Line.ID
    INNER JOIN ln_LineRoute2StopPoint
	    ON ln_LineRoute.ID = ln_LineRoute2StopPoint.LineRouteID
    WHERE
	    ln_LineRoute2StopPoint.StopPointID = @stopPointID
	)
END
</Definition>
      <Parameters>
        <ParameterMould Name="@stopPointID" MappingName="stopPointID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="ln_GetLinesForStopSign" MappingName="GetLinesForStopSign" CheckSum="-454208890" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[ln_GetLinesForStopSign]
(
	@stopSignID int
)
AS
BEGIN
	SELECT *
	FROM dbo.ln_LineView
	WHERE ID IN
	(
	SELECT ln_Line.ID FROM
	ln_Line
INNER JOIN ln_LineRoute
	ON ln_LineRoute.LineID = ln_Line.ID
INNER JOIN ln_LineRoute2StopPoint
	ON ln_LineRoute.ID = ln_LineRoute2StopPoint.LineRouteID
INNER JOIN ln_StopSign
	ON ln_StopSign.StopPointID = ln_LineRoute2StopPoint.StopPointID
WHERE
	ln_StopSign.ID = @stopSignId
	)
END
</Definition>
      <Parameters>
        <ParameterMould Name="@stopSignID" MappingName="stopSignID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
