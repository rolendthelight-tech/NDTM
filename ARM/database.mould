CREATE VIEW [dbo].[rms_ProcessTimeTableView]
AS
SELECT
	dbo.rms_ProcessTimeTable.ID,
	dbo.rms_ProcessInfo.Name,
	dbo.rms_ProcessTimeTable.StartTime,
	dbo.rms_ProcessTimeTable.Period,
	dbo.rms_ProcessTimeTable.Active,
	dbo.cor_Entity.CreatedDate,
	dbo.cor_Entity.ModifiedDate,
	dbo.cor_DataSource.Name AS DataSourceName
FROM
  dbo.rms_ProcessTimeTable
   LEFT OUTER JOIN
	dbo.rms_ProcessInfo ON dbo.rms_ProcessTimeTable.ProcessInfoID = dbo.rms_ProcessInfo.ID LEFT OUTER JOIN
	dbo.cor_Entity ON dbo.cor_Entity.ID = dbo.rms_ProcessTimeTable.ID LEFT OUTER JOIN
