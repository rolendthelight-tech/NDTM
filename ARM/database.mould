    <ProcedureMould Name="ln_GetLineRoutePath" MappingName="GetLineRoutePath" CheckSum="-1408215123" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[ln_GetLineRoutePath]
(
	@lineRouteID int
)
AS
SELECT
	geo_RoadView.*
FROM
	geo_RoadView
INNER JOIN ln_LineRoutePath
	ON ln_LineRoutePath.RoadID = geo_RoadView.ID
WHERE
	ln_LineRoutePath.LineRouteID = @lineRouteID
ORDER BY
	ln_LineRoutePath.OrderNumber
</Definition>
      <Parameters>
        <ParameterMould Name="@lineRouteID" MappingName="lineRouteID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="ln_GetLineRoutesForLine" MappingName="GetLineRoutesForLine" CheckSum="-513941727" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[ln_GetLineRoutesForLine]
(
	@lineID int
)
AS
BEGIN
	SELECT *
	FROM dbo.ln_LineRouteView
	WHERE dbo.ln_LineRouteView.ID IN
	(
		SELECT dbo.ln_LineRoute.ID
		FROM dbo.ln_LineRoute
		WHERE dbo.ln_LineRoute.LineID = @lineID
	)
END
</Definition>
      <Parameters>
        <ParameterMould Name="@lineID" MappingName="lineID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="ln_GetLineRoutesForStopPoint" MappingName="GetLineRoutesForStopPoint" CheckSum="714759816" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[ln_GetLineRoutesForStopPoint]
(
	@stopPointID int
)
AS
BEGIN
	SELECT *
	FROM dbo.ln_LineRouteView
	WHERE dbo.ln_LineRouteView.ID IN
	(
	SELECT dbo.ln_LineRoute.ID FROM
		dbo.ln_LineRoute
    INNER JOIN ln_LineRoute2StopPoint
	    ON ln_LineRoute.ID = ln_LineRoute2StopPoint.LineRouteID
    WHERE
	    ln_LineRoute2StopPoint.StopPointID = @stopPointID
	)
END
</Definition>
      <Parameters>
        <ParameterMould Name="@stopPointID" MappingName="stopPointID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
