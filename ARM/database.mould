CREATE VIEW [dbo].[tic_StopSignDemandView]
AS
SELECT
		dbo.tic_StopSignDemand.ID,
		dbo.tic_StopSignDemand.IncomingNumber,
		dbo.tic_StopSignDemand.PlanPerformanceDate,
		dbo.rms_DocumentView.Status,
		dbo.ln_StopSignView.ID AS StopSignID,
		dbo.ln_StopSignView.Name AS StopSignName,
		dbo.ln_StopSignView.LineRouteString,
		dbo.ln_StopSignView.StopPointNumber,
		dbo.ln_StopSignView.StopPointName,
		dbo.ln_StopSignView.District,
		dbo.ln_StopSignView.Address,
		dbo.ln_StopSignView.Direction,
		[dbo].[tic_GetStopSignDemandWorkTypes](dbo.tic_StopSignDemand.ID) AS WorkTypes,
		[dbo].[tic_GetStopSignDemandCost](dbo.tic_StopSignDemand.ID) AS Cost,
		dbo.ci_Organization.Name AS Executor,
		dbo.rms_DocumentType.Name AS DemandDocument,
		dbo.tic_StopSignDemand.PerformanceDate,
		dbo.rms_DocumentView.CreatedDate,
		dbo.rms_DocumentView.ModifiedDate,
		dbo.rms_DocumentView.Comment,
		dbo.rms_DocumentView.DataSource,
		dbo.rms_DocumentView.RowColor,
		[dbo].[rms_GetDocumentString](tic_WarrantView.Number, tic_WarrantView.CreatedDate) AS Warrant

FROM
	dbo.tic_StopSignDemand
LEFT OUTER JOIN
	dbo.rms_DocumentView
ON
	dbo.rms_DocumentView.ID = dbo.tic_StopSignDemand.ID
LEFT OUTER JOIN
	dbo.ln_StopSignView
ON
	dbo.ln_StopSignView.ID = dbo.tic_StopSignDemand.StopSignID
LEFT OUTER JOIN
	dbo.ci_Organization
ON
	dbo.ci_Organization.ID = dbo.tic_StopSignDemand.ExecutorID
LEFT OUTER JOIN
	dbo.rms_DocumentType
ON
	dbo.tic_StopSignDemand.DemandDocumentID = dbo.rms_DocumentType.ID
LEFT OUTER JOIN
	dbo.rms_Status
ON
	dbo.rms_DocumentType.ID = dbo.rms_Status.DocumentTypeID
LEFT OUTER JOIN
	tic_WarrantView
ON
	tic_WarrantView.ID = tic_StopSignDemand.WarrantID


</Definition>
    </ViewMould>
