CREATE VIEW [dbo].[pcc_WarrantView]
AS
SELECT     dbo.pcc_Warrant.ID, dbo.rms_DocumentView.Number, dbo.pcc_Warrant.DateOfIssue,
                      dbo.ci_GetEmployeeName(dbo.pcc_Warrant.ResponsiblePersonID1) AS ResponsiblePersonID1,
                      dbo.ci_GetEmployeeName(dbo.pcc_Warrant.ResponsiblePersonID2) AS ResponsiblePersonID2,
                      dbo.rms_DocumentView.Status,
                      dbo.rms_DocumentView.Comment,
                      dbo.pcc_GetFinanceChecksCount(dbo.pcc_Warrant.ID) AS FinanceChecksCount
FROM         dbo.pcc_Warrant LEFT OUTER JOIN
                      dbo.rms_DocumentView ON dbo.pcc_Warrant.ID = dbo.rms_DocumentView.ID
</Definition>
