CREATE FUNCTION [dbo].[ln_GetTerminalLineCount]
(
	@terminalID int
)
RETURNS int
AS

BEGIN

	DECLARE @ret INT

	SELECT @ret = COUNT(ID)
	FROM
		ln_Line
	WHERE
		EXISTS
		(
			SELECT NULL AS [Empty]
			FROM
				ln_LineRoute
			WHERE
				ln_Line.ID = ln_LineRoute.LineID
			AND
				(
					ln_LineRoute.BeginTerminalID = @terminalID
					OR
					ln_LineRoute.EndTerminalID = @terminalID
				)
		)

	RETURN @ret

END
</Definition>
