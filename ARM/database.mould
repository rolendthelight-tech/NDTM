    <ProcedureMould Name="fcs_CheckDuplicateSmartCardTransactionOnVehicleTrip" MappingName="CheckDuplicateSmartCardTransactionOnVehicleTrip" CheckSum="-344773335" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_CheckDuplicateSmartCardTransactionOnVehicleTrip]
(
	@login nvarchar(50) = NULL,
	@startDate datetime,
	@endDate datetime,
	@readOnlyFlag int,
	@duplicateSmartCardTransactionOnVehicleTrip bigint
)
AS
BEGIN


SELECT DISTINCT
					t.SmartCardNumber,
					v.ID VehicleTripID,
					u.ID UnitID,
					v.FirstTransactionDate,
					v.LastTransactionDate,
					e.[Type] EType
INTO #vehicleTripsInPeriod
FROM fcs_Transaction t
JOIN fcs_Equipment e
	ON e.ID=t.EquipmentID
JOIN fcs_VehicleTrip v
	ON v.ID = t.VehicleTripID
JOIN ln_VehicleUnit u
	ON v.VehicleUnitID=u.ID
WHERE t.Flags &amp; @readOnlyFlag = 0
	AND v.FirstTransactionDate
	BETWEEN @startDate AND @endDate

	SELECT DISTINCT
				v1.SmartCardNumber,
				v1.VehicleTripID,
				v2.VehicleTripID VehicleTripID2,
				v1.EType,
				v2.EType EType2
	INTO #vehicleTrips
	FROM #vehicleTripsInPeriod v1
		JOIN #vehicleTripsInPeriod v2
			ON v1.UnitID=v2.UnitID
		WHERE	v1.SmartCardNumber = v2.SmartCardNumber
				AND v2.FirstTransactionDate &gt;= v1.FirstTransactionDate
				AND v2.FirstTransactionDate &lt;= v1.LastTransactionDate
				AND v1.EType != v2.EType
DROP TABLE #vehicleTripsInPeriod;


UPDATE fcs_Transaction SET StatusCode = (ISNULL(StatusCode, 0) | @duplicateSmartCardTransactionOnVehicleTrip),
	Flags = (ISNULL(Flags, 0) 
						| dbo.fcs_GetInvalidFlag(ISNULL(StatusCode, 0) | @duplicateSmartCardTransactionOnVehicleTrip)),
	[Login] = @login,
	ModifiedDate = GETDATE()
WHERE
	ID IN (
	SELECT DISTINCT
			t.ID
	FROM (
		SELECT DISTINCT
				t.ID,
				t.SmartCardNumber,
				t.VehicleTripID,
				e.[Type] EType
		FROM fcs_Transaction t
		JOIN fcs_Equipment e
			ON t.EquipmentID = e.ID
		WHERE (t.Flags &amp; @readOnlyFlag) = 0
	) t
	JOIN #vehicleTrips v
		ON	t.SmartCardNumber = v.SmartCardNumber
			AND (t.VehicleTripID = v.VehicleTripID
				AND t.EType = v.EType
				OR t.VehicleTripID = v.VehicleTripID2
				AND t.EType = v.EType2
				)
	)

DECLARE @rowCount bigint = @@ROWCOUNT;
DROP TABLE #vehicleTrips;

SELECT 'RowCount' = @rowCount;

END
</Definition>
      <Parameters>
        <ParameterMould Name="@login" MappingName="login" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@readOnlyFlag" MappingName="readOnlyFlag" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@duplicateSmartCardTransactionOnVehicleTrip" MappingName="duplicateSmartCardTransactionOnVehicleTrip" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int64" Definition="bigint" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
