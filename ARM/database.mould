      <Definition>
CREATE VIEW [dbo].[pcc_StopPointPassangerFlowTableView]
AS
SELECT
 dbo.pcc_StopPointPassangerFlowTable.ID,
dbo.pcc_StopPointPassangerFlowTable.InspectionDate,
 dbo.ci_GetEmployeeName(dbo.pcc_StopPointPassangerFlowTable.ControllerID) AS Controler,
 dbo.ln_LineRouteView.Number AS LineNumber,
 dbo.ln_StopPointView.Name AS StopPointName,
 dbo.pcc_StopPointPassangerFlowTable.Alight,
 dbo.pcc_StopPointPassangerFlowTable.Board,
 dbo.pcc_GetStopPointPassangerFlowMeasurementsCount(dbo.pcc_StopPointPassangerFlowTable.ID) AS ChecksCount,
 rms_DocumentView.Status,
 rms_DocumentView.ModifiedDate,
 rms_Status.RowColor

FROM  dbo.pcc_StopPointPassangerFlowTable
 INNER JOIN
 rms_DocumentView ON pcc_StopPointPassangerFlowTable.ID = rms_DocumentView.ID
 LEFT OUTER JOIN
 dbo.rms_Employee
 ON dbo.pcc_StopPointPassangerFlowTable.ControllerID = dbo.rms_Employee.ID
 LEFT OUTER JOIN
 dbo.ln_StopPointView
 ON dbo.pcc_StopPointPassangerFlowTable.StopPointID = dbo.ln_StopPointView.ID
 LEFT OUTER JOIN
 dbo.ln_LineRouteView
 ON dbo.pcc_StopPointPassangerFlowTable.LineRouteID = dbo.ln_LineRouteView.ID
 INNER JOIN
 rms_Document ON pcc_StopPointPassangerFlowTable.ID = rms_Document.ID
LEFT OUTER JOIN
    dbo.rms_Status
    ON dbo.rms_Document.StatusID = dbo.rms_Status.ID
</Definition>
