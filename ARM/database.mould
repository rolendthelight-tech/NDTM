      <Definition>
CREATE VIEW [dbo].[geo_AddressView]
AS
SELECT
	geo_Address.ID,
	geo_RoadView.RoadType,
	geo_RoadView.Name AS RoadName,
	CONVERT(nvarchar(10), House.Number) + ISNULL(House.NumberSpecification, '') AS HouseNumber,
	House.Litera,
	House.HouseIndex,
	House.PostalCode,
	geo_Address.Comment,
	CrossRoad.RoadType AS CrossRoadType,
	CrossRoad.Name AS CrossRoadName,
	CONVERT(nvarchar(10), CrossHouse.Number) + ISNULL(CrossHouse.NumberSpecification, '') AS CrossHouseNumber,
	CrossHouse.Litera AS CrossLitera,
	CrossHouse.HouseIndex AS CrossIndex,
	geo_Address.RoadSide,
	geo_QualifiedAddress.CrossRoadSide,
	geo_QualifiedAddress.Comment AS QualifiedComment
FROM
	geo_Address
LEFT OUTER JOIN geo_Region
	ON geo_Region.ID = geo_Address.RegionID
LEFT OUTER JOIN geo_RoadView
	ON geo_RoadView.ID = geo_Address.RoadID
LEFT OUTER JOIN geo_House AS House
	ON House.ID = geo_Address.HouseID
LEFT OUTER JOIN geo_QualifiedAddress
	ON geo_Address.QualifiedAddressId = geo_QualifiedAddress.ID
LEFT JOIN geo_RoadView AS CrossRoad
	ON CrossRoad.ID = geo_QualifiedAddress.CrossRoadID
LEFT OUTER JOIN geo_House AS CrossHouse
	ON CrossHouse.ID = geo_QualifiedAddress.CrossHouseID
</Definition>
    </ViewMould>
