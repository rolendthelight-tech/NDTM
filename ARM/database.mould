    <ProcedureMould Name="cor_EventsHistoryReport" MappingName="EventsHistoryReport" CheckSum="1981976811" Schema="dbo">
      <Definition>
CREATE PROCEDURE cor_EventsHistoryReport
	@startDate datetime = NULL,
	@endDate datetime = NULL
AS
BEGIN
	SET NOCOUNT ON;

	IF @startDate IS NULL
	BEGIN

		SELECT
		TableName,
		SUM(Created) CreatedTotal,
		SUM(Updated) UpdatedTotal,
		SUM(Deleted) DeletedTotal
		FROM (
			SELECT
			TableName,
			'Created'=
				CASE EventType
					WHEN 0 THEN EventCount
					ELSE 0
				END,
			'Updated'=
				CASE EventType
					WHEN 1 THEN EventCount
					ELSE 0
				END,
			'Deleted'=
				CASE EventType
					WHEN 2 THEN EventCount
					ELSE 0
				END
			FROM (
				SELECT --top 1000

						TableName,
						EventType,
						COUNT(*) EventCount
				FROM

						cor_Entity

				INNER JOIN (
					SELECT EntityID, EventType
					FROM cor_History
					GROUP BY EntityID, EventType
					) t
					ON cor_Entity.ID = t.EntityID
				GROUP BY
						TableName, EventType
			) u
		) c
		GROUP BY	TableName
		ORDER BY TableName

	END
	ELSE
	BEGIN

		SELECT h.* INTO #history
		FROM cor_Revision r
		JOIN cor_History h
			ON r.ID=h.RevisionID
		WHERE r.EventTime BETWEEN @startDate AND @endDate;

		SELECT
		TableName,
		SUM(Created) CreatedTotal,
		SUM(Updated) UpdatedTotal,
		SUM(Deleted) DeletedTotal
		FROM (
			SELECT
			TableName,
			'Created'=
				CASE EventType
					WHEN 0 THEN EventCount
					ELSE 0
				END,
			'Updated'=
				CASE EventType
					WHEN 1 THEN EventCount
					ELSE 0
				END,
			'Deleted'=
				CASE EventType
					WHEN 2 THEN EventCount
					ELSE 0
				END
			FROM (
				SELECT --top 1000

						TableName,
						EventType,
						COUNT(*) EventCount
				FROM

						cor_Entity

				INNER JOIN (
					SELECT EntityID, EventType
					FROM #history
					GROUP BY EntityID, EventType
					) t
					ON cor_Entity.ID = t.EntityID
				GROUP BY
						TableName, EventType
			) u
		) c
		GROUP BY	TableName
		ORDER BY TableName

		DROP TABLE #history;
	END

END
</Definition>
      <Parameters>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
