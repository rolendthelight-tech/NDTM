      <Definition>
CREATE VIEW [dbo].[fcs_VehicleTripView]
AS
SELECT
	 vt.ID,
	 vt.TransactionLoadingID,
	 vt.DepartureDate,
	 vt.ArriveDate,
	 dbo.ln_GetTransportTypeShortName(lv.TransportType) + lv.Number AS LineNumber,
	 vt.Number AS TripNumber,
	 vt.LineWorkOrderNumber,
	 dlv.Operator,
	 dlv.Branch,
	 vu.TransportType,
	 vu.HullNumber,
	 vu.StateNumber,
	 vt.EquipmentType,
	 vt.FirstTransactionDate,
	 vt.LastTransactionDate,
	 vt.TransactionCount,
	 viv.Number AS VehicleIssueNumber

FROM
	fcs_VehicleTrip vt
LEFT OUTER JOIN
	ln_LineView lv ON lv.ID = vt.LineID
LEFT OUTER JOIN
	ln_VehicleUnitView vu ON vu.ID = vt.VehicleUnitID
LEFT OUTER JOIN
	fcs_DataLoadingView dlv ON dlv.ID = vt.TransactionLoadingID
LEFT OUTER JOIN
	fcs_VehicleIssueView viv ON viv.ID = vt.VehicleIssueID
</Definition>
    </ViewMould>
