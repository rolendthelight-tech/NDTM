CREATE VIEW [dbo].[rms_DataSourceView]
AS
SELECT
	cor_DataSource.*,
	cor_ClientApplication.Name AS ApplicationName,
	rms_Department.Name AS DepartmentName
FROM
	cor_DataSource
LEFT JOIN
	cor_ClientApplication
ON
	cor_ClientApplication.DataSourceID = cor_DataSource.ID
LEFT JOIN
	rms_Department
ON
	rms_Department.ID = cor_DataSource.ID
</Definition>
    </ViewMould>
