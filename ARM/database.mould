      <Definition>
CREATE VIEW [dbo].[map_ViewProfileItemView]
AS
SELECT     dbo.map_ViewProfileItem.ID, dbo.map_ViewProfile.Name AS ProfileName, dbo.map_Layer.Name AS LayerName,
                      dbo.map_ViewProfileItem.OrderNumber
FROM         dbo.map_ViewProfileItem LEFT OUTER JOIN
                      dbo.map_Layer ON dbo.map_ViewProfileItem.LayerID = dbo.map_Layer.ID LEFT OUTER JOIN
                      dbo.map_ViewProfile ON dbo.map_ViewProfileItem.ViewProfileID = dbo.map_ViewProfile.ID
</Definition>
