CREATE FUNCTION [dbo].[aux_AddString]
(
  @s1 nvarchar(max),
  @s2 nvarchar(max)
)
RETURNS nvarchar(max)
AS
BEGIN

	IF @s1 IS NULL
		RETURN @s2

	IF @s2 IS NULL
		RETURN @s1

	RETURN @s1 + @s2

END
</Definition>
