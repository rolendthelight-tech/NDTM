      <Definition>
CREATE VIEW [dbo].[ln_StopAreaView]
AS
SELECT
	ln_StopArea.ID,
	ln_StopArea.Number,
	(CASE ln_StopArea.Name WHEN '' THEN NULL ELSE ln_StopArea.Name END) AS Name,
	(CONVERT (nvarchar(10), ln_StopAreaType.Number) +
	CASE ISNULL(ln_StopAreaType.Code, '') WHEN '' THEN '' ELSE '. ' + ln_StopAreaType.Code END) AS [Type]
FROM
	ln_StopArea
LEFT OUTER JOIN ln_Stop
	ON ln_Stop.ID = ln_StopArea.StopID
LEFT OUTER JOIN ln_StopAreaType
	ON ln_StopAreaType.ID = ln_StopArea.TypeID
</Definition>
    </ViewMould>
