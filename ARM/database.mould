      <Definition>
CREATE VIEW [dbo].[ci_PassportBaseView]
AS
SELECT
	dbo.ci_Passport.ID,
	dbo.ci_Passport.Number,
	dbo.ci_Passport.Series,
	dbo.ci_Passport.DeliveryDate,
	dbo.ci_Passport.Department,
	dbo.ci_Passport.PlaceOfBirth,
	dbo.ci_Passport.DateOfBirth,
	dbo.geo_District.ShortName AS District,
	dbo.geo_Road.FullName AS RoadName,
	dbo.geo_GetRoadDirection(dbo.geo_Road.ID, dbo.geo_Address.RoadSide) AS Direction,
	dbo.geo_GetAddressString(dbo.ci_Passport.AddressID) AS Address
  FROM dbo.ci_Passport
LEFT OUTER JOIN
	dbo.geo_Address
	ON dbo.ci_Passport.AddressID = dbo.geo_Address.ID
LEFT OUTER JOIN
	dbo.geo_District
	ON dbo.geo_Address.DistrictID = dbo.geo_District.ID
LEFT OUTER JOIN
	dbo.geo_Road
	ON dbo.geo_Address.RoadID = dbo.geo_Road.ID
LEFT OUTER JOIN
	dbo.geo_QualifiedAddress
	ON dbo.geo_Address.QualifiedAddressId = dbo.geo_QualifiedAddress.ID
</Definition>
