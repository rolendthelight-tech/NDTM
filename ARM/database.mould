CREATE VIEW [dbo].[rms_DocumentTypeBaseView]
AS
SELECT [rms_DocumentType].[ID]
      ,[rms_DocumentType].[Code]
      ,[rms_DocumentType].[Name]
      ,[rms_DocumentType].[Description]
      ,[rms_DocumentType].[TableName]
      ,rms_Department.Name As Department
