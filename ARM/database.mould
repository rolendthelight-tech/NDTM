      <Definition>
CREATE VIEW [dbo].[fcs_EquipmentView]
AS
SELECT
	rms_DocumentView.ID,
	rms_DocumentView.Number,
	rms_DocumentView.[Status],
	fcs_Equipment.[Type],
	ln_Operator.Name AS Operator,
	ln_Operator.ShortName AS OperatorShortName,
	ln_OperatorBranch.Name AS OperatorBranch,
	ln_OperatorBranch.ShortName AS OperatorBranchShortName,
	fcs_Equipment.TransactionUploadDate,
	fcs_Equipment.TransactionCount,
	fcs_Equipment.DiagnosticDate,
	fcs_Equipment.MakingDate,
	fcs_Equipment.InstalledSoftwareVersion,
	fcs_Equipment.SoftwareUpdateDate,
	fcs_EquipmentDefect.Name AS Defect,
	rms_DocumentView.RowColor,
	rms_DocumentView.CreatedDate,
	rms_DocumentView.ModifiedDate,
	rms_DocumentView.Comment
FROM
	fcs_Equipment
LEFT OUTER JOIN
	ln_Operator
ON
	ln_Operator.ID = fcs_Equipment.OperatorID
LEFT OUTER JOIN
	ln_OperatorBranch
ON
	ln_OperatorBranch.ID = fcs_Equipment.OperatorBranchID
LEFT OUTER JOIN
	fcs_EquipmentDefect
ON
	fcs_EquipmentDefect.ID = fcs_Equipment.EquipmentDefectID
INNER JOIN
	rms_DocumentView
ON
	rms_DocumentView.ID = fcs_Equipment.ID
</Definition>
    </ViewMould>
