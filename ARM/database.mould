CREATE VIEW [dbo].[tm_VehicleTrackView]
AS
SELECT
	dbo.tm_VehicleTrack.ID,
	dbo.tm_VehicleTrack.WorkDay,
	dbo.tm_VehicleTrack.DepartureDate,
	dbo.tm_VehicleTrack.ArriveDate,
	dbo.tm_VehicleTrack.Duration,
	dbo.tm_VehicleTrack.Transactions,
	dbo.tm_VehicleTrack.TrackLength,
	dbo.tm_VehicleTrack.StopPoints,
	dbo.ln_VehicleUnitView.TransportType,
	dbo.ln_LineView.Number,
	dbo.ln_LineRouteView.Direction,
	dbo.ln_VehicleUnitView.Operator,
	dbo.ln_VehicleUnitView.HullNumber,
	dbo.ln_VehicleUnitView.StateNumber,
	dbo.tm_VehicleTrack.LoadDate,
	dbo.fcs_GetVehicleTrackItemCount(dbo.tm_VehicleTrack.ID) AS Relations0
FROM
	dbo.tm_VehicleTrack
INNER JOIN
	dbo.ln_LineView
		ON dbo.ln_LineView.ID = dbo.tm_VehicleTrack.LineID
INNER JOIN
	dbo.ln_LineRouteView
		ON dbo.ln_LineRouteView.ID = dbo.tm_VehicleTrack.LineRouteID
INNER JOIN
	dbo.ln_VehicleUnitView
		ON dbo.ln_VehicleUnitView.ID = dbo.tm_VehicleTrack.VehicleUnitID
INNER JOIN
	dbo.rms_Status
		ON dbo.rms_Status.ID = dbo.tm_VehicleTrack.StatusID
</Definition>
    </ViewMould>
