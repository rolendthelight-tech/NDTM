        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[ln_VehicleMotionTimeView]
AS
SELECT
	dbo.ln_VehicleMotionTime.ID,
	dbo.ln_VehicleMotionTime.TimeProfileIntervalID,
	dbo.ln_StopPoint2LineRouteView.OrderNumber,
	dbo.ln_StopPoint2LineRouteView.Name,
	dbo.ln_StopPoint2LineRouteView.StopPointName,
	dbo.ln_VehicleMotionTime.MotionTime,
	dbo.ln_StopPoint2LineRouteView.IsBoard,
	dbo.ln_StopPoint2LineRouteView.IsAlight,
	dbo.ln_StopPoint2LineRouteView.RoadName,
	dbo.ln_StopPoint2LineRouteView.Address
FROM
	dbo.ln_VehicleMotionTime
INNER JOIN
	dbo.ln_TimeProfileInterval ON dbo.ln_TimeProfileInterval.ID = dbo.ln_VehicleMotionTime.TimeProfileIntervalID
INNER JOIN
	dbo.ln_TimeProfile ON dbo.ln_TimeProfile.ID = dbo.ln_TimeProfileInterval.TimeProfileID
LEFT OUTER JOIN
	dbo.ln_StopPoint2LineRouteView
		 ON dbo.ln_VehicleMotionTime.StopPointID = dbo.ln_StopPoint2LineRouteView.ID
			AND dbo.ln_StopPoint2LineRouteView.LineRouteID = dbo.ln_TimeProfile.LineRouteID
</Definition>
    </ViewMould>
    <ViewMould Name="ln_VehiclePointView" MappingName="VehiclePointView" CheckSum="-935048972" Schema="dbo">
      <Columns>
        <ColumnMould Name="ID" MappingName="ID" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="X" MappingName="X" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="RealTypeMould" DbType="Double" Definition="float" />
        </ColumnMould>
        <ColumnMould Name="Y" MappingName="Y" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="RealTypeMould" DbType="Double" Definition="float" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[ln_VehiclePointView]
AS

SELECT
	ln_StopPoint.ID,
	map_GeoPoint.X,
	map_GeoPoint.Y
FROM
	ln_StopPoint
INNER JOIN
	map_Entity2GeoPoint
ON
	map_Entity2GeoPoint.EntityID = ln_StopPoint.ID
INNER JOIN
	map_Layer
ON
	map_Layer.ID = map_Entity2GeoPoint.LayerID
INNER JOIN
	map_GeoPoint
ON
	map_Entity2GeoPoint.GeoPointID = map_GeoPoint.ID
WHERE
	map_Layer.Alias = 'VehicleStopPoint'
AND
	map_Layer.TableName = 'ln_StopPoint'
</Definition>
    </ViewMould>
