    <FunctionMould Name="ci_GetInitials" MappingName="GetInitials" CheckSum="-1860985816" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@Name" MappingName="Name" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
        <ParameterMould Name="@Patronimic" MappingName="Patronimic" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
        <ParameterMould Name="@Surname" MappingName="Surname" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[ci_GetInitials]
(
	@Name nvarchar(50),
	@Patronimic nvarchar(50),
	@Surname nvarchar(50)
)
RETURNS nvarchar(60)
AS
BEGIN

	DECLARE @ret nvarchar(60)
	set @ret = IsNull(@Surname,'')

	if (@ret = '')
		return NULL

	if (@Name is not NULL and Len(@Name) &gt;= 1)
	begin
		set @ret = @ret + ' ' + Substring(@Name,0,2) + '.';
		if (@Patronimic is not NULL and Len(@Name) &gt;= 1)
			set @ret = @ret + Substring(@Patronimic,0,2) + '.';
	end

	return @ret;
END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(60)" Length="60" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
