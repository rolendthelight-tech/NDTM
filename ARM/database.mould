      </Columns>
      <Definition>
CREATE VIEW [dbo].[pcc_PassengerFlowTableView]
AS
SELECT
	pcc_PassengerFlowTable.ID,
	ln_LineView.Number AS LineNumber,
	pcc_WarrantView.Number AS WarrantNumber,
	ln_VehicleUnit.StateNumber,
	pcc_PassengerFlowTable.InspectionDate,
	dbo.pcc_GetPassengerFlowMeasurementsCount(pcc_PassengerFlowTable.ID) AS ChecksCount,
	ln_dirStart.Name AS StartPoint,
	ln_dirEnd.Name AS [EndPoint],
    pcc_PassengerFlowTable.TripsPerDay,
	pcc_PassengerFlowTable.Board,
	pcc_PassengerFlowTable.Alight,
	rms_DocumentView.Status,
	rms_DocumentView.ModifiedDate,
	rms_Status.RowColor
FROM
  pcc_PassengerFlowTable
INNER JOIN
  rms_DocumentView
    ON pcc_PassengerFlowTable.ID = rms_DocumentView.ID
LEFT OUTER JOIN
  pcc_WarrantView
    ON pcc_PassengerFlowTable.WarrantID = pcc_WarrantView.ID
LEFT OUTER JOIN
  ln_LineView
    ON pcc_PassengerFlowTable.LineID = ln_LineView.ID
LEFT OUTER JOIN
  ln_VehicleUnit
    ON ln_VehicleUnit.ID = pcc_PassengerFlowTable.VehicleUnitID
LEFT OUTER JOIN
  ln_Direction AS ln_dirStart
    ON ln_dirStart.ID = pcc_PassengerFlowTable.StartTerminalID
LEFT OUTER JOIN
  ln_Direction AS ln_dirEnd
    ON ln_dirEnd.ID = pcc_PassengerFlowTable.StartTerminalID
INNER JOIN
  rms_Document
    ON pcc_PassengerFlowTable.ID = rms_Document.ID
LEFT OUTER JOIN
  rms_Status
    ON rms_Document.StatusID = rms_Status.ID
</Definition>
    </ViewMould>
