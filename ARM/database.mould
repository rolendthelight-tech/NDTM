    <FunctionMould Name="tic_GetStopSignDemandWorkTypes" MappingName="GetStopSignDemandWorkTypes" CheckSum="1930933687" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@stopSignDemandID" MappingName="stopSignDemandID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[tic_GetStopSignDemandWorkTypes]
(
	@stopSignDemandID int
)
RETURNS nvarchar(1024)
AS
BEGIN
	DECLARE @ret nvarchar(1024)

	SELECT @ret = ''

	SELECT
		@ret = @ret + ', ' + Name
	FROM
		tic_StopSignWorkType
	INNER JOIN
		tic_StopSignDemand2StopSignWorkType
	ON
		tic_StopSignDemand2StopSignWorkType.StopSignWorkTypeID = tic_StopSignWorkType.ID
	WHERE
		tic_StopSignDemand2StopSignWorkType.StopSignDemandID = @stopSignDemandID

	IF (LEN(@ret) &gt; 2)
		SELECT @ret = SUBSTRING(@ret, 2, LEN(@ret) - 1)
	ELSE
		SELECT @ret = NULL

	RETURN @ret
END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(1024)" Length="1024" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
