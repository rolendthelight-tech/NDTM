      <Definition>
CREATE VIEW ln_RealEstateView
AS
SELECT
	ln_RealEstate.ID,
	ln_RealEstate.Name,
	geo_AddressView.RoadType,
	geo_AddressView.RoadName,
	geo_AddressView.HouseNumber,
	geo_AddressView.Litera,
	geo_AddressView.HouseIndex,
	ln_RealEstate.[Square],
	ln_RealtyDestination.Name AS RealtyDestination
FROM
	ln_RealEstate
LEFT OUTER JOIN
	geo_AddressView
ON
	ln_RealEstate.AddressID = geo_AddressView.ID
LEFT OUTER JOIN
	ln_RealtyDestination
ON
	ln_RealtyDestination.ID = ln_RealEstate.RealtyDestinationID
</Definition>
