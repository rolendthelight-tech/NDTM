      <Definition>
CREATE VIEW [dbo].[map_LayerBaseView]
AS
SELECT dbo.map_Layer.ID,
       dbo.map_Layer.Name,
       dbo.map_Layer.GeometryType,
       dbo.map_Layer.IsReadOnly,
       dbo.map_Layer.TableName,
       dbo.map_Layer.Alias,
       dbo.map_Style.StyleString As DefaultStyleString
  FROM dbo.map_Layer
INNER JOIN
    dbo.map_Style
    ON dbo.map_Style.ID = dbo.map_Layer.DefaultStyleID
</Definition>
    </ViewMould>
