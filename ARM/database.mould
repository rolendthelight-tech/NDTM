SELECT
	dbo.fcs_SmartCard.Number AS ID,
	CONVERT(nvarchar(20), dbo.fcs_SmartCard.Number) AS Number,
	dbo.fcs_SmartCardKind.Code AS SmartCardKind,
    dbo.fcs_SmartCardType.Code AS SmartCardType,
    dbo.fcs_SmartCard.IssueDate,
    dbo.rms_Status.Name AS Status,
    dbo.fcs_SmartCard.ModifiedDate
FROM
    dbo.fcs_SmartCard
LEFT OUTER JOIN
    dbo.rms_Status ON dbo.rms_Status.ID = dbo.fcs_SmartCard.StatusID
LEFT OUTER JOIN
    dbo.fcs_SmartCardKind ON dbo.fcs_SmartCard.SmartCardKindID = dbo.fcs_SmartCardKind.ID
LEFT OUTER JOIN
    dbo.fcs_SmartCardType ON dbo.fcs_SmartCardType.ID = dbo.fcs_SmartCardKind.SmartCardTypeID
</Definition>
