    <ViewMould Name="rn_RoadSegmentView" MappingName="RoadSegmentView" CheckSum="-497693869" Schema="dbo">
      <Columns>
        <ColumnMould Name="ID" MappingName="ID" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="Number" MappingName="Number" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="Name" MappingName="Name" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="RoadType" MappingName="RoadType" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="RoadName" MappingName="RoadName" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(100)" Length="100" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="FromNode" MappingName="FromNode" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(62)" Length="62" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="ToNode" MappingName="ToNode" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(62)" Length="62" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[rn_RoadSegmentView]
AS
SELECT
	rn_RoadSegment.ID,
	rn_RoadSegment.Number,
	(CASE rn_RoadSegment.Name WHEN '' THEN NULL ELSE rn_RoadSegment.Name END) AS Name,
	geo_RoadView.RoadType,
	geo_RoadView.Name AS RoadName,
	CONVERT(nvarchar(10), FromNode.Number)
	+ (CASE ISNULL(FromNode.Name, '') WHEN '' THEN '' ELSE '. ' + FromNode.Name END) AS FromNode,
	CONVERT(nvarchar(10), ToNode.Number)
	+ (CASE ISNULL(ToNode.Name, '') WHEN '' THEN '' ELSE '. ' + ToNode.Name END) AS ToNode
FROM
	rn_RoadSegment
LEFT JOIN rn_NodeView AS FromNode
	ON FromNode.ID = rn_RoadSegment.FromNodeID
LEFT JOIN rn_NodeView AS ToNode
	ON ToNode.ID = rn_RoadSegment.ToNodeID
LEFT JOIN geo_RoadView
	ON geo_RoadView.ID = rn_RoadSegment.RoadID
</Definition>
    </ViewMould>
