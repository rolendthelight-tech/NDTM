CREATE VIEW [dbo].[ln_DispatcherStationView]
AS
SELECT
	ln_TerminalView.ID,
	ln_TerminalView.Name,
	ln_DispatcherStation.Phone,
	dbo.ci_GetPersonName(ln_DispatcherStation.RoomOwnerID) AS RoomOwner,
	ln_DispatcherStation.[Square],
	ln_DispatcherStation.HasBuffet,
	ln_DispatcherStation.PostCount,
	[dbo].[ln_GetTerminalLineCount](ln_DispatcherStation.ID) AS LineCount,
	[dbo].[ln_GetDispatcherStationOrderCount](ln_DispatcherStation.ID) AS OrderCount,
	ln_TerminalView.RoadType,
	ln_TerminalView.RoadName,
	ln_TerminalView.HouseNumber,
	ln_TerminalView.Litera,
	ln_TerminalView.HouseIndex,
	ln_TerminalView.Comment,
	ln_TerminalView.RowColor
FROM
	ln_TerminalView
INNER JOIN
	ln_DispatcherStation
ON
	ln_DispatcherStation.ID = ln_TerminalView.ID
</Definition>
    </ViewMould>
