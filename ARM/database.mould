      <Definition>
CREATE VIEW [dbo].[rn_TransportSystemBaseView]
AS
SELECT dbo.rn_TransportSystem.ID,
       dbo.rn_TransportSystem.Code,
       dbo.rn_TransportSystem.Name,
       dbo.rn_TransportSystem.[Type],
       dbo.cor_Entity.CreatedDate,
       dbo.cor_Entity.ModifiedDate,
       dbo.cor_DataSource.Name As DataSourceName
  FROM dbo.rn_TransportSystem
INNER JOIN
    dbo.cor_Entity
    ON dbo.cor_Entity.ID = dbo.rn_TransportSystem.ID
LEFT OUTER JOIN
    dbo.cor_DataSource
    ON dbo.cor_DataSource.ID = dbo.cor_Entity.DataSourceID
