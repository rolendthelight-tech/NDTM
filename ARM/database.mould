    <ProcedureMould Name="fcs_MultyUpdateTransactionFlags" MappingName="MultyUpdateTransactionFlags" CheckSum="-506791340" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_MultyUpdateTransactionFlags]
(
	@login nvarchar(50) = NULL,
	@or_mask int,
	@and_mask int,
	@ids AS xml
)
AS
BEGIN
DECLARE @handle int;
DECLARE @readOnlyFlag int = 1;

EXEC sp_xml_preparedocument @handle output, @ids

SELECT
	CONVERT(int, CONVERT(varchar(16),[text])) AS ID
INTO
	#tmp
FROM
	OPENXML(@handle, '/*/id/text()')

UPDATE fcs_Transaction 
SET 
	Flags = ((ISNULL(Flags, 0) | @or_mask ) &amp; @and_mask) | dbo.fcs_GetInvalidFlag(StatusCode),
	[Login] = @login,
	ModifiedDate = GETDATE()
WHERE
	ID IN (SELECT ID FROM #tmp)

DROP TABLE #tmp

EXEC sp_xml_removedocument @handle

END
</Definition>
      <Parameters>
        <ParameterMould Name="@login" MappingName="login" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
        <ParameterMould Name="@or_mask" MappingName="or_mask" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@and_mask" MappingName="and_mask" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@ids" MappingName="ids" Direction="Input">
          <ParameterType xsi:type="XmlTypeMould" DbType="Xml" Definition="xml" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_MultyUpdateTransactionStatusCode" MappingName="MultyUpdateTransactionStatusCode" CheckSum="-506791340" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_MultyUpdateTransactionStatusCode]
(
	@login nvarchar(50) = NULL,
	@or_mask bigint,
	@and_mask bigint,
	@ids AS xml
)
AS
BEGIN
DECLARE @handle int;
DECLARE @readOnlyFlag int = 1;

EXEC sp_xml_preparedocument @handle output, @ids

SELECT	CONVERT(int, CONVERT(varchar(16),[text])) AS ID
INTO #tmp
FROM
	OPENXML(@handle, '/*/id/text()')

UPDATE fcs_Transaction 
SET 
	StatusCode = (ISNULL(StatusCode, 0) | @or_mask ) &amp; @and_mask,
	Flags = ISNULL(Flags, 0) | dbo.fcs_GetInvalidFlag((ISNULL(StatusCode, 0) | @or_mask ) &amp; @and_mask),
	[Login] = @login,
	ModifiedDate = GETDATE()
WHERE
	ID IN
	(
		SELECT ID FROM #tmp
	)
AND
	ISNULL(([Flags] &amp; @readOnlyFlag), 0) = 0

DROP TABLE #tmp

EXEC sp_xml_removedocument @handle

END
</Definition>
      <Parameters>
        <ParameterMould Name="@login" MappingName="login" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
        <ParameterMould Name="@or_mask" MappingName="or_mask" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int64" Definition="bigint" />
        </ParameterMould>
        <ParameterMould Name="@and_mask" MappingName="and_mask" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int64" Definition="bigint" />
        </ParameterMould>
        <ParameterMould Name="@ids" MappingName="ids" Direction="Input">
          <ParameterType xsi:type="XmlTypeMould" DbType="Xml" Definition="xml" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_MultyUpdateTransactionStatusCodeBySmartCardNumber" MappingName="MultyUpdateTransactionStatusCodeBySmartCardNumber" CheckSum="-1442941990" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_MultyUpdateTransactionStatusCodeBySmartCardNumber]
(
	@login nvarchar(50) = NULL,
	@or_mask bigint,
	@and_mask bigint,
	@numbers AS nvarchar(max)
)
AS
BEGIN
DECLARE @handle int;
DECLARE @readOnlyFlag int = 1;
DECLARE @rowCount bigint;

EXEC sp_xml_preparedocument @handle output, @numbers

SELECT
		CONVERT(bigint, CONVERT(varchar(16),[text])) AS Number
INTO #tmp
FROM
		OPENXML(@handle, '/*/n/text()', 2)

UPDATE fcs_Transaction 
SET 
	StatusCode = (ISNULL(StatusCode, 0) | @or_mask ) &amp; @and_mask,
	Flags = ISNULL(Flags, 0) | dbo.fcs_GetInvalidFlag((ISNULL(StatusCode, 0) | @or_mask ) &amp; @and_mask),
	[Login] = @login,
	ModifiedDate = GETDATE()
WHERE
	SmartCardNumber IN
	(
		SELECT Number FROM #tmp
	)
	AND	(Flags &amp; @readOnlyFlag) = 0
	--AND (ISNULL(StatusCode, 0) | @or_mask ) &amp; @and_mask != StatusCode;

SET @rowCount = @@ROWCOUNT;

DROP TABLE #tmp

EXEC sp_xml_removedocument @handle

SELECT 'RowCount' = @rowCount;

END
</Definition>
      <Parameters>
        <ParameterMould Name="@login" MappingName="login" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
        <ParameterMould Name="@or_mask" MappingName="or_mask" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int64" Definition="bigint" />
        </ParameterMould>
        <ParameterMould Name="@and_mask" MappingName="and_mask" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int64" Definition="bigint" />
        </ParameterMould>
        <ParameterMould Name="@numbers" MappingName="numbers" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(max)" Length="-1" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_ReportTLoadingsGroupedByDate" MappingName="ReportTLoadingsGroupedByDate" CheckSum="1333113213" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_ReportTLoadingsGroupedByDate]
@startDate datetime = NULL,
@endDate datetime = NULL,
@currentDay int = 0,
@currentMonth int = 0,
@currentYear int = 0,
@firstWorkHour int

AS
BEGIN
SET NOCOUNT ON;

DECLARE @dateIndexes table (DateGroupIndex int)

DECLARE @start datetime, @end datetime;
DECLARE @day int, @month int, @year int;
DECLARE @startHour int;

DECLARE @rawData table(	[Operator] nvarchar(16),
										[Branch] nvarchar(16),
										FileSize int,
										TotalCount int,
										InputFilePath nvarchar(512),
										DateGroupIndex int
										);
DECLARE @daylyOperators	table([Operator] nvarchar(16),
													[Branch] nvarchar(16),
													[DateGroupIndex] int
													);
DECLARE @filesGetData table([Operator] nvarchar(16),
												[Branch] nvarchar(16),
												FilesGet int,
												DateGroupIndex int
												);
DECLARE @ErrfilesData table([Operator] nvarchar(16),
												[Branch] nvarchar(16),
												ErrFiles int,
												DateGroupIndex int
												);

SELECT @start = @startDate;
SELECT @end = @endDate;

SELECT @day = @currentDay;
SELECT @year=@currentYear;
SELECT @month=@currentMonth;
SELECT @startHour=@firstWorkHour;

INSERT INTO @rawData(
					Operator,
					Branch,
					FileSize,
					TotalCount,
					InputFilePath,
					DateGroupIndex
					)
EXEC fcs_ReportTLoadingsRawData
		@startDate = @start,
		@endDate = @end,
		@currentDay = @day,
		@currentMonth = @month,
		@currentYear = @year,
		@firstWorkHour = @firstWorkHour;

INSERT INTO @dateIndexes (DateGroupIndex)
SELECT DateGroupIndex FROM @rawData
GROUP BY DateGroupIndex;

INSERT INTO @daylyOperators
SELECT	Operator,
				Branch,
				DateGroupIndex
FROM(
	SELECT	o.ShortName AS Operator,
					b.ShortName AS Branch
	FROM	dbo.fcs_TransactionSource t
	JOIN
		dbo.ln_Operator o ON o.ID = t.OperatorID
	LEFT OUTER JOIN
		dbo.ln_OperatorBranch b ON b.ID = t.OperatorBranchID
	GROUP BY o.ShortName, b.ShortName
	) o
CROSS JOIN @dateIndexes;

INSERT INTO @filesGetData (	[Operator],	[Branch], FilesGet,	DateGroupIndex	)
SELECT	[Operator],	[Branch],
		FilesGet =
				CASE
					WHEN g.FilesGet IS NULL THEN 0
				ELSE FilesGet
				END,
		DateGroupIndex
FROM
(SELECT	o.[Operator], o.[Branch], f.FilesGet, o.DateGroupIndex
FROM (
SELECT	[Operator],	[Branch], COUNT([InputFilePath]) AS FilesGet, GroupIndex
FROM(
	SELECT [Operator],	[Branch], [InputFilePath], MAX(DateGroupIndex) AS GroupIndex
	FROM @rawData
	GROUP BY [Operator],	[Branch], [InputFilePath]
	) f0
GROUP BY	[GroupIndex], [Operator], [Branch]
	)f
RIGHT OUTER JOIN @daylyOperators o
	ON f.Operator= o.Operator AND f.Branch=o.Branch AND f.GroupIndex=o.DateGroupIndex
) g;

INSERT INTO @ErrfilesData([Operator], [Branch], ErrFiles, DateGroupIndex)
SELECT	[Operator],	[Branch], ErrFiles,	GroupIndex
FROM (
SELECT	[Operator],	[Branch], COUNT([InputFilePath]) AS ErrFiles, GroupIndex
FROM
(	SELECT	[Operator],	[Branch], [InputFilePath], MAX(DateGroupIndex) AS GroupIndex
	FROM ( SELECT * FROM @rawData WHERE TotalCount=0 AND FileSize&gt;0	) e
	GROUP BY	[Operator], [Branch],	[InputFilePath]) f0
GROUP BY	[GroupIndex], [Operator], [Branch]	)f


SELECT DateGroupIndex, Operator, Branch, FilesGet, ErrFiles, FilesGet-ErrFiles AS FilesOk
FROM
(	SELECT f.DateGroupIndex, f.[Operator], f.[Branch], f.FilesGet,
	ErrFiles =
		CASE
			WHEN e.ErrFiles IS NULL THEN 0
			ELSE e.ErrFiles
		END
FROM @filesGetData f LEFT JOIN @ErrfilesData e ON f.DateGroupIndex=e.DateGroupIndex AND f.Operator=e.Operator AND f.Branch=e.Branch) t
ORDER BY DateGroupIndex, Operator, Branch;

RETURN 0;

END
</Definition>
      <Parameters>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@currentDay" MappingName="currentDay" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@currentMonth" MappingName="currentMonth" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@currentYear" MappingName="currentYear" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_ReportTLoadingsRawData" MappingName="ReportTLoadingsRawData" CheckSum="1333113213" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_ReportTLoadingsRawData]
													@startDate datetime = NULL,
													@endDate datetime = NULL,
													@currentDay int = 0,
													@currentMonth int = 0,
													@currentYear int = 0,
													@firstWorkHour int
AS
BEGIN
	SET NOCOUNT ON;

	IF @startDate IS NOT NULL
		AND @endDate IS NOT NULL
  BEGIN
		SELECT
		  [Operator],
		  [Branch],
		  [FileSize],
		  [TotalCount],
		  [InputFilePath],
			@currentYear AS DateGroupIndex
		FROM [fcs_TransactionLoadingView]
		WHERE FtpUploadDate BETWEEN DATEADD(HOUR, @firstWorkHour, @startDate) AND DATEADD(HOUR, @firstWorkHour, @endDate)

		RETURN 0;
  END

	IF @currentDay != 0
	BEGIN
			SELECT
			  [Operator],
			  [Branch],
			  [FileSize],
			  [TotalCount],
			  [InputFilePath],
				@currentDay AS DateGroupIndex
			FROM	[fcs_TransactionLoadingView]
			WHERE MONTH(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate]))= @currentMonth
				AND DAY(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate]))= @currentDay
				AND YEAR(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate])) = @currentYear;
	END
  ELSE IF @currentMonth!=0
  BEGIN
			SELECT
			  [Operator],
			  [Branch],
			  [FileSize],
			  [TotalCount],
			  [InputFilePath],
				DAY(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate])) AS DateGroupIndex
			FROM	[fcs_TransactionLoadingView]
			WHERE MONTH(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate]))= @currentMonth
				AND YEAR(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate])) = @currentYear;
  END
  ELSE
  BEGIN
			SELECT
			  [Operator],
			  [Branch],
			  [FileSize],
			  [TotalCount],
			  [InputFilePath],
				MONTH(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate])) AS DateGroupIndex
			FROM [fcs_TransactionLoadingView]
			WHERE YEAR(DATEADD(HOUR, -@firstWorkHour, [FtpUploadDate])) = @currentYear;
  END

END
</Definition>
      <Parameters>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@currentDay" MappingName="currentDay" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@currentMonth" MappingName="currentMonth" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@currentYear" MappingName="currentYear" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
