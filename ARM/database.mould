          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[ln_VehicleUnitFleetView]
AS
SELECT
	ln_TerminalView.ID,
	ln_VehicleUnitFleet.TransportType,
	dbo.ci_GetInitials(ci_Man.Name, ci_Man.Patronimic, ci_Man.Surname) AS Secretary,
	ln_TerminalView.Name,
	ISNULL(ln_Operator.ShortName, ln_Operator.Name) AS Operator,
	ISNULL(ln_OperatorBranch.ShortName, ln_OperatorBranch.Name) AS OperatorBranch,
	ln_TerminalView.RoadType,
	ln_TerminalView.RoadName,
	ln_TerminalView.HouseNumber,
	ln_TerminalView.Litera,
	ln_TerminalView.HouseIndex,
	ln_TerminalView.Comment,
	ln_TerminalView.RowColor
FROM
	ln_VehicleUnitFleet
INNER JOIN
	ln_TerminalView
ON
	ln_VehicleUnitFleet.ID = ln_TerminalView.ID
LEFT JOIN
	ln_Operator
ON
	ln_VehicleUnitFleet.OperatorID = ln_Operator.ID
LEFT JOIN
	ln_OperatorBranch
ON
	ln_VehicleUnitFleet.OperatorBranchID = ln_OperatorBranch.ID
LEFT JOIN
	ci_Man
ON
	ci_Man.ID = ln_VehicleUnitFleet.SecretaryID
</Definition>
    </ViewMould>
