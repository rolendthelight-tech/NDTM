        <ColumnMould Name="HasMiniature" MappingName="HasMiniature" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="BooleanTypeMould" DbType="Boolean" Definition="bit" />
        </ColumnMould>
        <ColumnMould Name="HasFileData" MappingName="HasFileData" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="BooleanTypeMould" DbType="Boolean" Definition="bit" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[cor_PictureView]
AS
SELECT
	ID,
	(CASE ISNULL(MiniatureID, 0) WHEN 0 THEN CONVERT(bit, 0) ELSE CONVERT(bit, 1) END) AS HasMiniature,
	(CASE ISNULL(FileDataGuid, '00000000-0000-0000-0000-000000000000')
		WHEN '00000000-0000-0000-0000-000000000000' THEN CONVERT(bit, 0) ELSE CONVERT(bit, 1) END) AS HasFileData
 FROM cor_Picture
</Definition>
    </ViewMould>
