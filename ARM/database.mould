      <Definition>
CREATE VIEW [dbo].[fcs_EquipedOperatorBranchListView]
AS
	SELECT	o.Name AS OperatorName,
					o.ShortName AS OperatorShortName,
					b.Name AS BranchName,
					b.ShortName AS BranchShortName
	FROM	dbo.fcs_TransactionSource t
	JOIN
		dbo.ln_Operator o ON o.ID = t.OperatorID
	LEFT OUTER JOIN
		dbo.ln_OperatorBranch b ON b.ID = t.OperatorBranchID
	GROUP BY o.Name, o.ShortName, b.Name, b.ShortName
</Definition>
    </ViewMould>
