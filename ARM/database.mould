CREATE VIEW
	[dbo].[pcc_PassengerFlowMeasurementView]
AS
SELECT
	pcc_PassengerFlowMeasurement.ID,
	ln_StopPoint.Name AS StopPointName,
	ln_Direction.Name as Direction,
    pcc_PassengerFlowMeasurement.ArrivalTime as ArrivalTime,
	pcc_PassengerFlowMeasurement.Alight,
	pcc_PassengerFlowMeasurement.Board,
	pcc_PassengerFlowMeasurement.VehicleBrand
FROM
	pcc_PassengerFlowMeasurement

INNER JOIN
	ln_StopPoint
ON
	ln_StopPoint.ID = pcc_PassengerFlowMeasurement.StopPointID

LEFT JOIN
	ln_Direction
ON
	ln_Direction.ID = pcc_PassengerFlowMeasurement.DirectionID
</Definition>
