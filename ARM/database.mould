          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(128)" Length="128" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="MotionTime" MappingName="MotionTime" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="DateTimeTypeMould" DbType="Time" Definition="time(7)" />
        </ColumnMould>
        <ColumnMould Name="IsBoard" MappingName="IsBoard" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="BooleanTypeMould" DbType="Boolean" Definition="bit" />
        </ColumnMould>
        <ColumnMould Name="IsAlight" MappingName="IsAlight" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="BooleanTypeMould" DbType="Boolean" Definition="bit" />
        </ColumnMould>
        <ColumnMould Name="RoadName" MappingName="RoadName" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(100)" Length="100" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="Address" MappingName="Address" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
