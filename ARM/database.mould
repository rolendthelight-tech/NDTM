      <Definition>
CREATE VIEW [dbo].[ln_StopSignView]
AS
SELECT
	dbo.ln_StopSign.ID,
	dbo.aux_EmptyString2Null(dbo.rms_DocumentView.Status) AS Status,
	dbo.ln_StopSign.TransportType,
	dbo.ln_StopSign.Name,
	dbo.ln_StopPointBaseView.District,
	dbo.ln_StopPointBaseView.RoadName,
	dbo.ln_StopPointBaseView.Number AS StopPointNumber,
	dbo.ln_StopPointBaseView.Name AS StopPointName,
	dbo.ln_GetLineRouteStopSignString(dbo.ln_StopSign.ID) AS LineRouteString,
	dbo.ln_StopPointBaseView.Direction,
	dbo.ln_StopPointBaseView.Address,
	dbo.ln_StopSignType.Name AS StopSignType,
	dbo.ln_StopSign.ArrangementHeight,
	dbo.ln_StopSignArrangement.Place AS ArrangementPlace,
	dbo.ln_StopSignMount.Code + '. ' + dbo.ln_StopSignMount.Name AS Mount,
	dbo.ln_InfoFieldType.Code + '. ' + dbo.ln_InfoFieldType.Info AS Info,
	dbo.ln_GetStopSignLineRoutesCount(dbo.ln_StopSign.ID) AS LineRoutesCount,
	dbo.aux_EmptyString2Null(rms_Status.Name) AS CheckStatus,
	dbo.aux_EmptyString2Null(dbo.rms_DocumentView.DataSource) AS DataSource,
	dbo.rms_DocumentView.ModifiedDate,
	dbo.rms_DocumentView.RowColor
FROM
	dbo.ln_StopSign
INNER JOIN
	dbo.rms_DocumentView ON dbo.rms_DocumentView.ID = dbo.ln_StopSign.ID
LEFT OUTER JOIN
	dbo.rms_Status ON dbo.ln_StopSign.CheckStatusID = rms_Status.ID
LEFT OUTER JOIN
	dbo.ln_StopPointBaseView ON dbo.ln_StopSign.StopPointID = dbo.ln_StopPointBaseView.ID
LEFT OUTER JOIN
	dbo.ln_StopSignType ON dbo.ln_StopSign.StopSignTypeID = dbo.ln_StopSignType.ID
LEFT OUTER JOIN
	dbo.ln_StopSignArrangement ON dbo.ln_StopSign.ArrangementID = dbo.ln_StopSignArrangement.ID
LEFT OUTER JOIN
	dbo.ln_StopSignMount ON dbo.ln_StopSign.MountID = dbo.ln_StopSignMount.ID
LEFT OUTER JOIN
	dbo.ln_InfoFieldType ON dbo.ln_StopSign.InfoFieldTypeID = dbo.ln_InfoFieldType.ID
</Definition>
    </ViewMould>
