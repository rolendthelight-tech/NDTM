CREATE FUNCTION [dbo].[aux_AddBrackets]
(
  @beforeBracket nvarchar(max),
  @text          nvarchar(max),
  @afterBracket  nvarchar(max)
)
RETURNS nvarchar(max)
AS
BEGIN

	IF @text IS NOT NULL
		RETURN @beforeBracket + @text + @afterBracket

	RETURN @text

END
</Definition>
