      <Definition>
CREATE VIEW [dbo].[ln_StopPointBaseView]
AS
SELECT
	dbo.ln_StopPoint.ID,
	dbo.rms_Document.Number,
	dbo.geo_District.ShortName AS District,
	dbo.geo_Road.FullName AS RoadName,
    dbo.aux_EmptyString2Null(dbo.ln_StopPoint.Name) AS Name,
    dbo.ln_GetTransportTypeStopPointString(dbo.ln_StopPoint.ID) AS TransportTypeString,
    dbo.ln_GetLineRouteStopPointString(dbo.ln_StopPoint.ID) AS LineRouteString,
    dbo.geo_GetRoadDirection(dbo.geo_Road.ID, dbo.geo_Address.RoadSide) AS Direction,
    dbo.geo_GetAddressString(dbo.ln_StopPoint.AddressID) AS Address,
    dbo.ln_StopPoint.IsRoadSign516,
    dbo.ln_StopPoint.IsRoadMark,
    dbo.ln_StopPoint.IsBoarding,
    dbo.aux_EmptyString2Null(dbo.rms_Status.Name) AS Status,
    dbo.ln_StopPoint.ActivationDate, dbo.ln_StopPoint.PavilionCount,
    dbo.aux_EmptyString2Null(dbo.cor_DataSource.Name) AS DataSource,
    dbo.cor_Entity.ModifiedDate,
    dbo.rms_Status.RowColor
FROM
	dbo.ln_StopPoint
INNER JOIN
    dbo.rms_Document
    ON dbo.rms_Document.ID = dbo.ln_StopPoint.ID
INNER JOIN
    dbo.cor_Entity
    ON dbo.cor_Entity.ID = dbo.ln_StopPoint.ID
LEFT OUTER JOIN
    dbo.geo_Address
    ON dbo.ln_StopPoint.AddressID = dbo.geo_Address.ID
LEFT OUTER JOIN
    dbo.geo_District
    ON dbo.geo_Address.DistrictID = dbo.geo_District.ID
LEFT OUTER JOIN
    dbo.geo_Road
    ON dbo.geo_Address.RoadID = dbo.geo_Road.ID
LEFT OUTER JOIN
    dbo.geo_QualifiedAddress
    ON dbo.geo_Address.QualifiedAddressId = dbo.geo_QualifiedAddress.ID
LEFT OUTER JOIN
    dbo.rms_Status
    ON dbo.rms_Document.StatusID = dbo.rms_Status.ID
LEFT OUTER JOIN
    dbo.cor_DataSource
    ON dbo.cor_Entity.DataSourceID = dbo.cor_DataSource.ID
</Definition>
    </ViewMould>
