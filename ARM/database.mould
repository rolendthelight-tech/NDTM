CREATE VIEW [dbo].[tic_MaterialView]
AS
SELECT
	tic_Material.ID,
	tic_Material.Code,
	tic_Material.Name,
	tic_MeasurementUnit.ShortName AS MeasurementUnit,
	tic_Material.Price
FROM
	tic_Material
LEFT OUTER JOIN tic_MeasurementUnit
	ON tic_Material.MeasurementUnitID = tic_MeasurementUnit.ID
</Definition>
