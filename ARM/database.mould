      <Definition>
CREATE VIEW [dbo].[cor_EntityBaseView]
AS
SELECT dbo.cor_Entity.ID,
       dbo.cor_Entity.TableName,
       dbo.cor_Entity.CreatedDate,
       dbo.cor_Entity.ModifiedDate,
       dbo.cor_Entity.DataSourceID,
       dbo.cor_DataSource.[Name] As DataSourceName
  FROM dbo.cor_Entity
LEFT OUTER JOIN
    dbo.cor_DataSource
    ON dbo.cor_DataSource.ID = dbo.cor_Entity.DataSourceID
</Definition>
