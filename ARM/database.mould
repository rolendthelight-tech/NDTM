)
AS
SELECT
	ln_PlacePointView.*
FROM
	ln_PlacePointView
INNER JOIN ln_LineRoute2StopPoint
	ON ln_LineRoute2StopPoint.StopPointID = ln_PlacePointView.ID
WHERE
	ln_LineRoute2StopPoint.LineRouteID = @lineRouteID
ORDER BY ln_LineRoute2StopPoint.OrderNumber
</Definition>
