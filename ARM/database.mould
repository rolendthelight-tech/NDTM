CREATE VIEW [dbo].[ln_TurnRingView]
AS
SELECT
	ln_TerminalView.ID,
	ln_TerminalView.Name,
	ln_TurnRing.TransportType,
	dbo.ci_GetPersonName(ln_TurnRing.OwnerID) AS [Owner],
	ln_TerminalView.RoadType,
	ln_TerminalView.RoadName,
	ln_TerminalView.HouseNumber,
	ln_TerminalView.Litera,
	ln_TerminalView.HouseIndex,
	ln_TerminalView.Comment,
	ln_TerminalView.RowColor,
	dbo.ln_GetTerminalLineCount(ln_TerminalView.ID) AS LineCount
FROM
	ln_TerminalView
INNER JOIN
	ln_TurnRing
ON
	ln_TurnRing.ID = ln_TerminalView.ID
</Definition>
