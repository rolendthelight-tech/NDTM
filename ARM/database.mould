      <Definition>
CREATE VIEW [dbo].[fcs_BoardEquipmentView]
AS
SELECT
	e.*,
	ln_VehicleType.Name AS VehicleType,
	ln_VehicleUnit.CardNumber,
	ln_VehicleUnit.HullNumber,
	ln_VehicleUnitClass.ShortName AS VehicleUnitClass,
	dbo.aux_EmptyString2Null(ln_VehicleUnit.StateNumber) AS StateNumber,
	fcs_BoardEquipment.Number_BK,
	fcs_BoardEquipment.Number_IUsR1,
	fcs_BoardEquipment.Number_IUsR2,
	fcs_BoardEquipment.Number_KB,
	fcs_BoardEquipment.Number_UsR1,
	fcs_BoardEquipment.Number_UsR2,
	fcs_BoardEquipment.Number_UsR3,
	fcs_BoardEquipment.Number_UsR4
FROM
	fcs_BoardEquipment
INNER JOIN
	fcs_EquipmentView e
ON
	e.ID = fcs_BoardEquipment.ID
LEFT OUTER JOIN
	ln_VehicleUnit
ON
	ln_VehicleUnit.ID = fcs_BoardEquipment.VehicleUnitID
LEFT OUTER JOIN
	ln_VehicleType
ON
	ln_VehicleType.ID = ln_VehicleUnit.VehicleTypeID
LEFT OUTER JOIN
	ln_VehicleUnitClass
ON
	ln_VehicleUnitClass.ID = ln_VehicleType.VehicleUnitClassID
</Definition>
    </ViewMould>
