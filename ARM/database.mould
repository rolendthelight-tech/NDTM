      <Definition>
CREATE VIEW [dbo].[ln_TimeProfileView]
AS
SELECT
	dbo.ln_TimeProfile.ID,
	dbo.rms_DocumentView.Number,
	dbo.ln_LineRouteView.TransportType,
	dbo.ln_LineRouteView.Number + ' (' + dbo.ln_LineRouteView.Direction + ')' AS LineRouteNumber,
	dbo.ln_TimeProfile.StartDate,
	dbo.ln_TimeProfile.FinishDate,
	dbo.ln_TimeProfile.IsInterval,
	dbo.rms_DocumentView.Status,
	dbo.rms_DocumentView.CreatedDate,
	dbo.rms_DocumentView.ModifiedDate,
	dbo.rms_DocumentView.RowColor,
	dbo.ln_GetTimeProfileIntervalCount(dbo.ln_TimeProfile.ID)	AS TimeProfileIntervalCount,
	dbo.ln_GetTimeProfileVehicleJourneyCount(dbo.ln_TimeProfile.ID) AS VehicleJourneyCount

FROM
	dbo.ln_TimeProfile
LEFT OUTER JOIN
	dbo.ln_LineRouteView
		ON dbo.ln_LineRouteView.ID = dbo.ln_TimeProfile.LineRouteID
LEFT OUTER JOIN
	dbo.rms_DocumentView
		ON dbo.rms_DocumentView.ID = dbo.ln_TimeProfile.ID
</Definition>
    </ViewMould>
