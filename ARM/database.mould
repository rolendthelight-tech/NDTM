        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[ln_VehicleUnitView]
AS
SELECT
	ln_VehicleUnit.ID,
	ln_Operator.ShortName AS Operator,
	ln_OperatorBranch.ShortName AS OperatorBranch,
	ln_VehicleType.TransportType,
	ln_VehicleUnit.HullNumber,
	ln_VehicleUnit.StateNumber,
	ln_VehicleUnitClass.ShortName AS VehicleUnitClass,
	ln_VehicleType.Name AS [Type],
	ln_VehicleType.IsElectric
FROM
	ln_VehicleUnit
LEFT JOIN
	ln_VehicleType
	  ON ln_VehicleType.ID = ln_VehicleUnit.VehicleTypeID
LEFT JOIN
	ln_Operator
		ON ln_Operator.ID = ln_VehicleUnit.OperatorID
LEFT JOIN
	ln_OperatorBranch
		ON ln_OperatorBranch.ID = ln_VehicleUnit.OperatorBranchID
LEFT JOIN
	ln_VehicleUnitClass
		ON ln_VehicleUnitClass.ID = ln_VehicleType.VehicleUnitClassID
</Definition>
    </ViewMould>
