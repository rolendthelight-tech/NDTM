      <Parameters>
        <ParameterMould Name="@roadSide" MappingName="roadSide" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Byte" Definition="tinyint" />
        </ParameterMould>
      </Parameters>
      <Definition>
