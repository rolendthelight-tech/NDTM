      </Columns>
      <Definition>
CREATE VIEW [dbo].[fcs_DataLoadingView]
AS
SELECT
	d.ID,
	o.ShortName AS Operator,
	b.ShortName AS Branch,
	d.FirstRecordDate,
	d.FtpUploadDate,
	d.DbUploadDate,
	d.TotalCount,
	d.LoadedCount,
	d.TotalCount-d.LoadedCount AS NotLoadedCount,
	d.DuplicateCount,
	d.ErrorCount,
	d.WarningCount,
	d.StatusCode,
	d.FileSize,
	d.InputFilePath,
	d.ProcessedFilePath,
	d.ProcessingTime
FROM
	dbo.fcs_DataLoading d
LEFT OUTER JOIN
	dbo.fcs_TransactionSource s ON s.ID = d.TransactionSourceID
LEFT OUTER JOIN
	dbo.ln_Operator o ON o.ID = s.OperatorID
LEFT OUTER JOIN
	dbo.ln_OperatorBranch b ON b.ID = s.OperatorBranchID
</Definition>
    </ViewMould>
    <ViewMould Name="fcs_EquipedOperatorBranchListView" MappingName="EquipedOperatorBranchListView" CheckSum="890205557" Schema="dbo">
