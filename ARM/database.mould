CREATE VIEW [dbo].[fcs_TransactionSourceView]
AS
SELECT
	dbo.fcs_TransactionSource.ID,
	dbo.ln_Operator.ShortName AS Operator,
	dbo.ln_Operator.Code AS OperatorCode,
    dbo.ln_OperatorBranch.ShortName AS OperatorBranch,
    dbo.ln_OperatorBranch.Code AS OperatorBranchCode,
    dbo.fcs_TransactionSource.FtpSourceFolder,
    dbo.fcs_TransactionSource.FtpBackupFolder,
    dbo.fcs_TransactionSource.FtpDestinationFolder,
    dbo.fcs_TransactionSource.Email
FROM
	dbo.fcs_TransactionSource
LEFT OUTER JOIN
	dbo.ln_Operator ON dbo.fcs_TransactionSource.OperatorID = dbo.ln_Operator.ID
LEFT OUTER JOIN
	dbo.ln_OperatorBranch ON dbo.fcs_TransactionSource.OperatorBranchID = dbo.ln_OperatorBranch.ID
</Definition>
