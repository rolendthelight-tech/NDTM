          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="CreatedDate" MappingName="CreatedDate" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ColumnMould>
        <ColumnMould Name="ModifiedDate" MappingName="ModifiedDate" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[ln_LineView]
AS
SELECT
	l.ID,
	l.Number,
	l.TransportType,
	l.Commercial,
	[dbo].[ln_GetLineOperatorString](l.ID) AS Operators,
	l.Code,
  dbo.ln_GetLineRoutesForLineCount(l.ID) AS LineRoutesCount,
  dbo.rn_TransportSystem.Name AS TransportSystem,
  e.CreatedDate,
  e.ModifiedDate
FROM
	dbo.ln_Line l
JOIN
	cor_Entity e
		ON e.ID = l.ID
LEFT OUTER JOIN
	dbo.rn_TransportSystem
		ON	dbo.rn_TransportSystem.ID = l.TransportSystemID
</Definition>
    </ViewMould>
