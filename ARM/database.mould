CREATE PROCEDURE [dbo].[pcc_GetTimeProfileChecks]
(
	@pcc_TimeProfileCheckTableID int
)
AS

BEGIN

	SELECT * FROM pcc_TimeProfileCheckView
	INNER JOIN
	dbo.pcc_TimeProfileCheck
	ON dbo.pcc_TimeProfileCheck.ID = dbo.pcc_TimeProfileCheckView.ID
	WHERE pcc_TimeProfileCheck.TimeProfileCheckTableID = @pcc_TimeProfileCheckTableID

END
</Definition>
