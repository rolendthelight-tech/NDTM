      <Definition>
CREATE VIEW [dbo].[tic_StopPointCheckView]
AS
SELECT
	dbo.tic_StopPointCheck.ID,
	dbo.tic_StopPointCheck.PlanPerformanceDate,
	dbo.rms_DocumentView.Status,
	dbo.ln_StopPointView.Number AS StopPointNumber,
	dbo.ln_StopPointView.Name AS StopPointName,
    dbo.ln_StopPointView.LineRouteString,
	dbo.ln_StopPointView.Direction,
	dbo.ln_StopPointView.District,
	dbo.ln_StopPointView.Address,
    dbo.ln_StopPointView.IsRoadSign516,
    dbo.ln_StopPointView.IsRoadMark,
    dbo.ln_StopPointView.IsBoarding,
    dbo.ln_StopPointView.SignCount,
    dbo.ln_StopPointView.PavilionCount,
	StopPointStatus.Name AS StopPointStatus,
	dbo.tic_StopPointCheck.PerformanceDate,
	dbo.ci_GetInitials(dbo.rms_EmployeeView.Name,
	dbo.rms_EmployeeView.Patronimic,
	dbo.rms_EmployeeView.Surname) AS Inspector,
	dbo.rms_DocumentView.ModifiedDate,
	dbo.rms_DocumentView.DataSource,
	dbo.rms_DocumentView.RowColor

FROM
   dbo.tic_StopPointCheck
LEFT OUTER JOIN
   dbo.rms_DocumentView
       ON dbo.rms_DocumentView.ID = dbo.tic_StopPointCheck.ID
LEFT OUTER JOIN
   dbo.ln_StopPointView
       ON dbo.ln_StopPointView.ID = dbo.tic_StopPointCheck.StopPointID
LEFT OUTER JOIN
   dbo.rms_Status AS StopPointStatus
       ON StopPointStatus.ID = dbo.tic_StopPointCheck.StopPointStatusID
LEFT OUTER JOIN
   dbo.rms_EmployeeView
       ON dbo.rms_EmployeeView.ID = dbo.tic_StopPointCheck.InspectorID
</Definition>
    </ViewMould>
