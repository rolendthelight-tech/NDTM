CREATE VIEW [dbo].[fcs_TransactionLoadingView]
AS
SELECT
	t.ID,
	d.Operator,
	d.Branch,
	d.FirstRecordDate,
	t.EquipmentType,
	t.IsTechnological,
	d.FtpUploadDate,
	d.DbUploadDate,
	d.TotalCount,
	d.LoadedCount,
	d.NotLoadedCount,
	d.DuplicateCount,
	d.ErrorCount,
	d.WarningCount,
	d.StatusCode,
	d.FileSize,
	d.InputFilePath,
	d.ProcessedFilePath,
	d.ProcessingTime
FROM
	dbo.fcs_TransactionLoading t
LEFT OUTER JOIN
	dbo.fcs_DataLoadingView d ON d.ID = t.ID
</Definition>
