CREATE VIEW [dbo].[fcs_TransactionView]
AS

SELECT
	 tr.ID,
	 tr.FileLineNumber,
	 tr.TransactionLoadingID,
	 tr.VehicleTripID,
	 tsv.Operator,
	 tsv.OperatorBranch,
	 tr.StopPointID,
	 tr.LineRouteID,
	 tr.Date,
	 tr.IssueDate,
	 tr.ExpiryDate,
	 tr.[Flags],
	 (CASE tr.StatusCode WHEN 0 THEN NULL ELSE tr.StatusCode END) AS StatusCode,
	 tr.SmartCardNumber,
	 sct.Code AS SmartCardType,
	 sck.Code AS SmartCardKind,
	 dbo.ln_GetTransportTypeShortName(l.TransportType) + l.Number AS LineNumber,
	 vt.Number AS TripNumber,
	 vu.ID AS VehicleUnitID,
	 vu.TransportType,
	 vu.HullNumber,
	 vu.StateNumber,
	 vt.LineWorkOrderNumber,
	 eq.Type AS EquipmentType,
	 eq.Number AS EquipmentNumber,
	 [ReadOnly]= ISNULL(CONVERT(bit, tr.[Flags]&amp;1), 0),
	 [IsValid]= ~ISNULL(CONVERT(bit, tr.[Flags]&amp;2), 0),
	 dbo.ci_GetEmployeeNameByLogin(tr.[Login]) UserName,
	 tr.ModifiedDate
FROM
	fcs_Transaction tr
LEFT OUTER JOIN
    fcs_SmartCardKind sck ON sck.ID = tr.SmartCardKindID
LEFT OUTER JOIN
    fcs_SmartCardType sct ON sct.ID = sck.SmartCardTypeID
LEFT OUTER JOIN
	fcs_VehicleTrip vt ON vt.ID = tr.VehicleTripID
LEFT OUTER JOIN
   ln_Line l ON vt.LineID = l.ID
LEFT OUTER JOIN
   ln_VehicleUnitView vu ON vu.ID = vt.VehicleUnitID
LEFT OUTER JOIN
   fcs_DataLoading dld ON dld.ID = tr.TransactionLoadingID
LEFT OUTER JOIN
   fcs_TransactionSourceView tsv ON tsv.ID = dld.TransactionSourceID
LEFT OUTER JOIN
	fcs_EquipmentView eq ON eq.ID = tr.EquipmentID





</Definition>
    </ViewMould>
