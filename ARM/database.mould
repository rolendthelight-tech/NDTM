      <Definition>
CREATE VIEW map_LayerView
AS
SELECT
	map_Layer.ID,
	Alias,
	Name,
	GeometryType,
	TableName,
	map_Style.StyleString AS DefaultStyle,
	ISNULL([dbo].[map_GetLayerPointCount](map_Layer.ID, map_Layer.GeometryType), 0) AS PointCount
FROM
	map_Layer
INNER JOIN
	map_Style
ON
	map_Style.ID = map_Layer.DefaultStyleID
</Definition>
