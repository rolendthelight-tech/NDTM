        <ColumnMould Name="Type" MappingName="Type" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(62)" Length="62" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="X" MappingName="X" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="RealTypeMould" DbType="Double" Definition="float" />
        </ColumnMould>
        <ColumnMould Name="Y" MappingName="Y" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="RealTypeMould" DbType="Double" Definition="float" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[ln_StopView]
AS
SELECT
	ln_Stop.ID,
	ln_Stop.Number,
	(CASE ln_Stop.Name WHEN '' THEN NULL ELSE ln_Stop.Name END) AS Name,
	CONVERT(nvarchar(10), ln_StopType.Number) +
	(CASE ISNULL(ln_StopType.Name, '') WHEN '' THEN '' ELSE '. ' + ln_StopType.Name END) AS [Type],
	X,
	Y
FROM
ln_Stop
LEFT OUTER JOIN ln_StopType
	ON ln_StopType.ID = ln_Stop.TypeID
LEFT OUTER JOIN
	map_Entity2GeoPoint
ON map_Entity2GeoPoint.EntityID = ln_Stop.ID
LEFT OUTER JOIN map_GeoPoint
	ON map_Entity2GeoPoint.GeoPointID = map_GeoPoint.ID
</Definition>
    </ViewMould>
