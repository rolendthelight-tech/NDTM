CREATE VIEW [dbo].[tic_ExecutorsWorkStopSignView]
AS
SELECT
	dbo.tic_ExecutorsWorkStopSign.ID,
	dbo.tic_ExecutorsWorkStopSign.Name,
	dbo.ci_OrganizationView.Form,
	dbo.ci_OrganizationView.Name AS OrganizationName,
	dbo.ci_OrganizationView.NPR,
	dbo.ci_OrganizationView.Fax,
	dbo.ci_OrganizationView.Secretary,
	dbo.ci_OrganizationView.ContactPerson,
	dbo.ci_OrganizationView.PostalCode,
	dbo.ci_OrganizationView.RoadType,
	dbo.ci_OrganizationView.RoadName,
	dbo.ci_OrganizationView.HouseNumber,
	dbo.ci_OrganizationView.HouseIndex,
	dbo.ci_OrganizationView.Litera
FROM
	dbo.tic_ExecutorsWorkStopSign
INNER JOIN
	dbo.ci_OrganizationView ON dbo.tic_ExecutorsWorkStopSign.OrganizationID = dbo.ci_OrganizationView.ID
</Definition>
    </ViewMould>
