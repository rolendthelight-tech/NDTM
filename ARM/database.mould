      <Definition>
CREATE VIEW [dbo].[rms_DocumentView]
AS
SELECT
	dbo.rms_Document.ID,
	dbo.rms_Document.Number,
	dbo.rms_DocumentType.Name,
	dbo.aux_EmptyString2Null(dbo.rms_Status.Name) AS Status,
	dbo.cor_Entity.CreatedDate,
	dbo.cor_Entity.ModifiedDate,
	dbo.aux_EmptyString2Null(dbo.rms_Document.Comment) AS Comment,
	dbo.aux_EmptyString2Null(dbo.cor_DataSource.Name) AS DataSource,
	dbo.rms_Document.RevisionID,
	dbo.rms_Status.RowColor
FROM
	dbo.rms_Document
INNER JOIN
	dbo.cor_Entity ON dbo.cor_Entity.ID = dbo.rms_Document.ID
LEFT OUTER JOIN
	dbo.rms_Status ON dbo.rms_Status.ID = dbo.rms_Document.StatusID
LEFT OUTER JOIN
	dbo.cor_DataSource ON dbo.cor_DataSource.ID = dbo.cor_Entity.DataSourceID
LEFT OUTER JOIN
	dbo.rms_DocumentType ON dbo.rms_Document.DocumentTypeID = dbo.rms_DocumentType.ID
</Definition>
    </ViewMould>
