      <Definition>CREATE VIEW dbo.tm_AnalysisTimeIntervalView
AS
SELECT     dbo.tm_AnalysisTimeInterval.ID, dbo.tm_AnalysisTimeInterval.[Begin], dbo.tm_AnalysisTimeInterval.[End], dbo.tm_AnalysisTask.Active, 
                      dbo.tm_AnalysisTask.Name, dbo.tm_AnalysisTask.WeekDay, dbo.tm_AnalysisTask.StartTime, dbo.tm_AnalysisTask.FinishTime, 
                      dbo.tm_AnalysisTask.Comment
FROM         dbo.tm_AnalysisTimeInterval LEFT OUTER JOIN
                      dbo.tm_AnalysisTask ON dbo.tm_AnalysisTimeInterval.AnalysisTaskID = dbo.tm_AnalysisTask.ID
</Definition>
