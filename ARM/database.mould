        </ColumnMould>
        <ColumnMould Name="BranchName" MappingName="BranchName" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(128)" Length="128" Multiline="false" Collation="Cyrillic_General_CI_AS" />
