    <FunctionMould Name="geo_GetAddressString" MappingName="GetAddressString" CheckSum="-440611424" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@addressId" MappingName="addressId" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[geo_GetAddressString]
(
	@addressId int
)
RETURNS nvarchar(max)
AS
BEGIN
	DECLARE @road nvarchar(128)
	DECLARE @houseID int
	DECLARE @roadSide tinyint
	DECLARE @comment nvarchar(128)
	DECLARE @qualifiedAddressId int

	DECLARE @string nvarchar(512)

	SELECT @road               = dbo.aux_EmptyString2Null( geo_Road.FullName ),
		   @houseID            = HouseID,
		   @roadSide           = RoadSide,
		   @comment            = Comment,
		   @qualifiedAddressId = QualifiedAddressId

    FROM
      geo_Address
    LEFT OUTER JOIN
	  geo_Road       ON geo_Address.RoadID = geo_Road.ID

	WHERE geo_Address.ID = @addressId

	IF @road IS NULL
	  SET @string = @comment
	ELSE
	BEGIN

	  SET @string = @road

	  IF @houseID IS NOT NULL
	    SET @string += dbo.aux_AddPrefixNN(' д.', dbo.geo_GetHouseString(@houseID))
	  ELSE
	  BEGIN
        IF @roadSide IS NOT NULL
	      SET @string = @road + dbo.geo_GetRoadSideString(@roadSide)
	  END

	  SET @string += ISNULL(dbo.aux_AddBrackets(' (', @comment, ')'), '')

    END

	RETURN dbo.aux_EmptyString2Null( @string
	                                  + dbo.aux_AddPrefixNN(' / ', dbo.geo_GetQualifiedAddressString(@qualifiedAddressId))
	                                )
END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(max)" Length="-1" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
    <FunctionMould Name="geo_GetHouseString" MappingName="GetHouseString" CheckSum="-2090903486" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@houseId" MappingName="houseId" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[geo_GetHouseString]
(
	@houseId int
)
RETURNS nvarchar(max)
AS
BEGIN
	DECLARE @t nvarchar(128)

	SELECT @t =
	        CONVERT(nvarchar(10), Number)
	        + ISNULL(NumberSpecification, '')
			+ dbo.aux_AddPrefixNN(' к.', HouseIndex)
			+ dbo.aux_AddPrefixNN(' л.', Litera)

    FROM geo_House

	WHERE ID = @houseId

	RETURN dbo.aux_EmptyString2Null( @t )
END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(max)" Length="-1" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
    <FunctionMould Name="geo_GetQualifiedAddressString" MappingName="GetQualifiedAddressString" CheckSum="-440611424" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@addressId" MappingName="addressId" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[geo_GetQualifiedAddressString]
(
	@addressId int
)
RETURNS nvarchar(max)
AS
BEGIN
	DECLARE @road nvarchar(128)
	DECLARE @houseID int
	DECLARE @roadSide tinyint
	DECLARE @comment nvarchar(128)
	DECLARE @qualifiedAddressId int

	DECLARE @string nvarchar(512)

	SELECT @road               = dbo.aux_EmptyString2Null( geo_Road.FullName ),
		   @houseID            = CrossHouseID,
		   @roadSide           = CrossRoadSide,
		   @comment            = Comment

    FROM
      geo_QualifiedAddress
    LEFT OUTER JOIN
	  geo_Road       ON geo_QualifiedAddress.CrossRoadID = geo_Road.ID

	WHERE geo_QualifiedAddress.ID = @addressId

	IF @road IS NULL
	  SET @string = @comment
	ELSE
	BEGIN

	  SET @string = @road

	  IF @houseID IS NOT NULL
	    SET @string += dbo.aux_AddPrefixNN(' д.', dbo.geo_GetHouseString(@houseID))
	  ELSE
	  BEGIN
        IF @roadSide IS NOT NULL
	      SET @string = @road + dbo.aux_AddPrefixNN(', ', dbo.geo_GetRoadSideString(@roadSide))
	  END

	  SET @string += ISNULL(dbo.aux_AddBrackets(' (', @comment, ')'), '')

    END

	RETURN @string

END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(max)" Length="-1" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
    <FunctionMould Name="geo_GetRoadDirection" MappingName="GetRoadDirection" CheckSum="78897563" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@roadID" MappingName="roadID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@roadSide" MappingName="roadSide" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Byte" Definition="tinyint" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[geo_GetRoadDirection]
(
  @roadID int,
  @roadSide tinyint
)
RETURNS nvarchar(518)
AS
BEGIN

	DECLARE @r1 int
	DECLARE @r2 int
	DECLARE @t1 nvarchar(259)
	DECLARE @t2 nvarchar(518)

	IF @roadSide IS NULL OR @roadSide = 1
		SELECT @r1 = geo_Road.FromRoadID, @r2 = geo_Road.ToRoadID
		FROM geo_Road
		WHERE geo_Road.ID = @roadID
	ELSE
		SELECT @r2 = geo_Road.FromRoadID, @r1 = geo_Road.ToRoadID
		FROM geo_Road
		WHERE geo_Road.ID = @roadID

    IF @r1 IS NOT NULL
		SELECT @t1 = dbo.aux_AddPrefix('от ', geo_Road.GenitiveCase)
		FROM geo_Road
		WHERE geo_Road.ID = @r1

    IF @r2 IS NOT NULL
		SELECT @t2 = dbo.aux_AddPrefix(' к ', geo_Road.DativeCase)
		FROM geo_Road
		WHERE geo_Road.ID = @r2

    IF @t1 IS NOT NULL
      BEGIN
        IF @t2 IS NOT NULL
          RETURN @t1 + @t2
        ELSE
          RETURN @t1
	  END
    ELSE
      BEGIN
        IF @t2 IS NOT NULL
          RETURN @t2
      END


	RETURN NULL

END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(518)" Length="518" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
