CREATE VIEW [dbo].[tic_WarrantView]
AS
SELECT
	dbo.rms_DocumentView.ID,
	dbo.rms_DocumentView.Number,
	dbo.rms_DocumentView.Status,
	dbo.tic_Warrant.PlanPerformanceDate,
	dbo.tic_Warrant.PerformanceDate,
	dbo.ci_GetInitials(rms_Employee.Name, rms_Employee.Patronimic, rms_Employee.Surname) AS Brigadier,
	[dbo].[tic_GetWarrantStopSignDemandsCount](dbo.rms_DocumentView.ID) AS StopSignDemandCount,
	dbo.rms_DocumentView.Comment,
	dbo.rms_DocumentView.CreatedDate,
	dbo.rms_DocumentView.ModifiedDate,
	dbo.rms_DocumentView.DataSource,
	dbo.rms_DocumentView.RowColor
FROM
    dbo.tic_Warrant
LEFT OUTER JOIN
    dbo.rms_DocumentView
ON
	dbo.tic_Warrant.ID = dbo.rms_DocumentView.ID
LEFT OUTER JOIN
	rms_Employee
ON
	rms_Employee.ID = tic_Warrant.BrigadierID

</Definition>
