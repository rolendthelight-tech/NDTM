    <ProcedureMould Name="fcs_UpdateSmartCardAttributesByTransactions" MappingName="UpdateSmartCardAttributesByTransactions" CheckSum="-955573245" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_UpdateSmartCardAttributesByTransactions]
(
  @minTransactionID int
)
AS

UPDATE fcs_SmartCard
SET
  SmartCardKindID = T.SmartCardKindID,
  IssueDate = T.IssueDate,
  ExpiryDate = T.ExpiryDate,
  RemainingResource = T.RemainingResource,
  ModifiedDate = T.ModifiedDate
FROM
(
	SELECT TOP 100 N.SmartCardNumber, SmartCardKindID, IssueDate, ExpiryDate, RemainingResource, N.[Date] AS ModifiedDate
	FROM fcs_Transaction AS N
	INNER JOIN
	(
	  SELECT SmartCardNumber, MAX([Date]) AS ModifiedDate
	  FROM fcs_Transaction
	  WHERE
	   ID &gt;= @minTransactionID
	  GROUP BY
	   SmartCardNumber
	 ) AS M
	 ON
	   M.SmartCardNumber = N.SmartCardNumber AND M.ModifiedDate = N.[Date]
) AS T
WHERE
  fcs_SmartCard.Number = T.SmartCardNumber AND fcs_SmartCard.ModifiedDate &lt; T.ModifiedDate
</Definition>
      <Parameters>
        <ParameterMould Name="@minTransactionID" MappingName="minTransactionID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_VehicleIssue_Delete" MappingName="VehicleIssue_Delete" CheckSum="-1224745567" Schema="dbo">
      <Definition>
CREATE PROCEDURE [fcs_VehicleIssue_Delete]
													@startDate datetime,
													@endDate datetime,
													@firstWorkHour int
AS
BEGIN
	SET NOCOUNT ON;

		DELETE FROM [fcs_VehicleIssue]
		WHERE [StartWorkDate] BETWEEN DATEADD(HOUR, @firstWorkHour, @startDate) AND DATEADD(HOUR, @firstWorkHour, @endDate)
			AND	[FinishWorkDate] BETWEEN DATEADD(HOUR, @firstWorkHour, @startDate) AND DATEADD(HOUR, @firstWorkHour, @endDate)
		RETURN 0;

END
</Definition>
      <Parameters>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
