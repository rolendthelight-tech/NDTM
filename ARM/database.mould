CREATE VIEW [dbo].[rms_DepartmentBaseView]
AS
SELECT dbo.rms_Department.ID,
       dbo.rms_Department.Name,
       dbo.rms_Department.FullName,
       ParentDepartment.ID As ParentDepartment,
       dbo.cor_Entity.CreatedDate,
       dbo.cor_Entity.ModifiedDate,
       dbo.cor_DataSource.Name As DataSourceName
  FROM dbo.rms_Department
INNER JOIN
    dbo.cor_Entity
    ON dbo.cor_Entity.ID = dbo.rms_Department.ID
LEFT OUTER JOIN
    dbo.cor_DataSource
    ON dbo.cor_DataSource.ID = dbo.cor_Entity.DataSourceID
LEFT OUTER JOIN
    dbo.rms_Department AS ParentDepartment
    ON dbo.rms_Department.ParentID = ParentDepartment.ID
</Definition>
