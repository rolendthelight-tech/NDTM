      <Definition>
CREATE VIEW [dbo].[fcs_CheckEmployeeView]
AS
SELECT
	dbo.fcs_CheckEmployee.ID,
	dbo.ln_Operator.ShortName AS Operator,
    dbo.ln_OperatorBranch.ShortName AS OperatorBranch,
    dbo.rms_EmployeeView.Surname,
    dbo.rms_EmployeeView.Name,
    dbo.rms_EmployeeView.Patronimic,
    dbo.fcs_CheckEmployee.ClockNumber,
    dbo.fcs_CheckEmployee.CardNumber,
    dbo.rms_EmployeeView.Status,
    dbo.rms_EmployeeView.RowColor
FROM
	dbo.fcs_CheckEmployee
LEFT OUTER JOIN
    dbo.rms_EmployeeView ON rms_EmployeeView.ID = dbo.fcs_CheckEmployee.ID
LEFT OUTER JOIN
	dbo.ln_Operator ON dbo.fcs_CheckEmployee.OperatorID = dbo.ln_Operator.ID
LEFT OUTER JOIN
	dbo.ln_OperatorBranch ON dbo.fcs_CheckEmployee.OperatorBranchID = dbo.ln_OperatorBranch.ID
</Definition>
