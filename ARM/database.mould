      <Definition>
CREATE VIEW pcc_CheckInitiatorView
AS
SELECT
	pcc_CheckInitiator.ID,
	rms_CorrespondenceView.IncomingNumber,
	rms_CorrespondenceView.Comment AS Correspondence,
	ci_PersonView.Name AS Person,
	pcc_CheckInitiator.Comment
FROM
	pcc_CheckInitiator
LEFT OUTER JOIN
	rms_CorrespondenceView
ON pcc_CheckInitiator.CorrespondenceID = rms_CorrespondenceView.ID
LEFT OUTER JOIN
	ci_PersonView
ON ci_PersonView.ID = pcc_CheckInitiator.PersonID
</Definition>
