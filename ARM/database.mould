      <Definition>

CREATE VIEW [dbo].[fcs_TechnologicalTransactionView]
AS

SELECT
	 tr.ID,
	 tr.FileLineNumber,
	 tr.TransactionLoadingID,
	 tr.VehicleTripID,
	 tsv.Operator,
	 tsv.OperatorBranch,
	 tr.Date,
	 tr.[Flags],
	 CONVERT(nvarchar(32), tr.StatusCode) AS StatusCode,
	 tr.SmartCardNumber,
	 sct.Code AS SmartCardType,
	 sck.Code AS SmartCardKind,
	 dbo.ln_GetTransportTypeShortName(l.TransportType) + l.Number AS LineNumber,
	 vt.Number AS TripNumber,
	 vu.ID AS VehicleUnitID,
	 vu.TransportType,
	 vu.HullNumber,
	 vu.StateNumber,
	 vt.LineWorkOrderNumber,
	 eq.Type AS EquipmentType,
	 doc.Number AS EquipmentNumber,
	 [ReadOnly]= 
			CASE
				WHEN  tr.[Flags]&amp;1 &gt; 0 THEN 1 --ReadOnly Flag
				ELSE 0
			END,
		[IsValid]=
			CASE 
				WHEN tr.[Flags]&amp;2 &gt; 0 THEN 0 --Invalid Flag
				ELSE 1
			END,
	 dbo.ci_GetEmployeeNameByLogin(tr.[Login]) UserName,
	 tr.ModifiedDate
FROM
	fcs_TechnologicalTransaction tr
LEFT OUTER JOIN
    fcs_SmartCardKind sck ON sck.ID = tr.SmartCardKindID
LEFT OUTER JOIN
    fcs_SmartCardType sct ON sct.ID = sck.SmartCardTypeID
LEFT OUTER JOIN
	fcs_VehicleTrip vt ON vt.ID = tr.VehicleTripID
LEFT OUTER JOIN
   ln_Line l ON vt.LineID = l.ID
LEFT OUTER JOIN
   ln_VehicleUnitView vu ON vu.ID = vt.VehicleUnitID
LEFT OUTER JOIN
   fcs_DataLoading dld ON dld.ID = tr.TransactionLoadingID
LEFT OUTER JOIN
   fcs_TransactionSourceView tsv ON tsv.ID = dld.TransactionSourceID
LEFT OUTER JOIN
	fcs_Equipment eq ON eq.ID = tr.EquipmentID
LEFT OUTER JOIN
	rms_Document doc ON doc.ID = eq.ID



</Definition>
    </ViewMould>
