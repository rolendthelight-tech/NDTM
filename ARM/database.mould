	cor_Entity.ID,
	rn_RestrictedZoneType.Name,
	rn_RestrictedZone.StartDate,
	rn_RestrictedZone.EndDate,
	rn_RestrictedZone.[Description],
	cor_Entity.CreatedDate,
	cor_Entity.ModifiedDate
