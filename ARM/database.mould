    <ProcedureMould Name="tm_GetTransactionSet0" MappingName="GetTransactionSet0" CheckSum="-574183082" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[tm_GetTransactionSet0]
(
  @firstDay   DATE,
  @lastDay    DATE,  -- Не включает
  @startTime  TIME,
  @finishTime TIME,
  @firstWorkHour int
)
AS

DECLARE
  @first DATETIME,
  @last  DATETIME,
  @start  TIME,
  @finish TIME
BEGIN

  IF @firstDay IS NULL
    SET @first = '1900-01-01';
  ELSE
	SET @first = DATEADD(hh, @firstWorkHour, CAST(@firstDay AS DATETIME));

  IF @lastDay IS NULL
    SET @last = '2100-01-01';
  ELSE
	SET @last = DATEADD(hh, @firstWorkHour, CAST(@lastDay AS DATETIME));

  IF @startTime IS NULL
    SET @start = '00:00:00';
  ELSE
	SET @start = @startTime;

  IF @finishTime IS NULL
    SET @finish = '23:59:59.997';
  ELSE
	SET @finish = @finishTime;

SELECT
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE) AS WorkDay,
	fcs_VehicleTrip.VehicleUnitID,
	fcs_VehicleTrip.LineID,
	COUNT(*) AS Transactions
FROM
	fcs_Transaction
LEFT OUTER JOIN
	fcs_VehicleTrip ON fcs_VehicleTrip.ID = fcs_Transaction.VehicleTripID
WHERE
	fcs_Transaction.[Date] BETWEEN @first AND @last
  AND
	CAST(fcs_Transaction.[Date] AS TIME) BETWEEN @start AND @finish
GROUP BY
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE),
	fcs_VehicleTrip.VehicleUnitID,
	fcs_VehicleTrip.LineID

END
</Definition>
      <Parameters>
        <ParameterMould Name="@firstDay" MappingName="firstDay" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Date" Definition="date" />
        </ParameterMould>
        <ParameterMould Name="@lastDay" MappingName="lastDay" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Date" Definition="date" />
        </ParameterMould>
        <ParameterMould Name="@startTime" MappingName="startTime" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Time" Definition="time(7)" />
        </ParameterMould>
        <ParameterMould Name="@finishTime" MappingName="finishTime" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Time" Definition="time(7)" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="tm_GetTransactionSet1" MappingName="GetTransactionSet1" CheckSum="-574183082" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[tm_GetTransactionSet1]
(
  @firstDay   DATE,
  @lastDay    DATE,  -- Не включает
  @startTime  TIME,
  @finishTime TIME,
  @firstWorkHour int
)
AS

DECLARE
  @first DATETIME,
  @last  DATETIME,
  @start  TIME,
  @finish TIME
BEGIN

  IF @firstDay IS NULL
    SET @first = '1900-01-01';
  ELSE
	SET @first = DATEADD(hh, @firstWorkHour, CAST(@firstDay AS DATETIME));

  IF @lastDay IS NULL
    SET @last = '2100-01-01';
  ELSE
	SET @last = DATEADD(hh, @firstWorkHour, CAST(@lastDay AS DATETIME));

  IF @startTime IS NULL
    SET @start = '00:00:00';
  ELSE
	SET @start = @startTime;

  IF @finishTime IS NULL
    SET @finish = '23:59:59.997';
  ELSE
	SET @finish = @finishTime;

SELECT
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE) AS WorkDay,
	fcs_TransactionSource.OperatorID,
	fcs_TransactionSource.OperatorBranchID,
	fcs_VehicleTrip.LineID,
	COUNT(*) AS Transactions
FROM
	fcs_Transaction
LEFT OUTER JOIN
   fcs_DataLoading ON fcs_DataLoading.ID = fcs_Transaction.TransactionLoadingID
LEFT OUTER JOIN
   fcs_TransactionSource ON fcs_TransactionSource.ID = fcs_DataLoading.TransactionSourceID
LEFT OUTER JOIN
	fcs_VehicleTrip ON fcs_VehicleTrip.ID = fcs_Transaction.VehicleTripID
WHERE
	fcs_Transaction.[Date] BETWEEN @first AND @last
  AND
	CAST(fcs_Transaction.[Date] AS TIME) BETWEEN @start AND @finish
GROUP BY
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE),
	fcs_TransactionSource.OperatorID,
	fcs_TransactionSource.OperatorBranchID,
	fcs_VehicleTrip.LineID

END
</Definition>
      <Parameters>
        <ParameterMould Name="@firstDay" MappingName="firstDay" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Date" Definition="date" />
        </ParameterMould>
        <ParameterMould Name="@lastDay" MappingName="lastDay" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Date" Definition="date" />
        </ParameterMould>
        <ParameterMould Name="@startTime" MappingName="startTime" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Time" Definition="time(7)" />
        </ParameterMould>
        <ParameterMould Name="@finishTime" MappingName="finishTime" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Time" Definition="time(7)" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="tm_GetTransactionSet2" MappingName="GetTransactionSet2" CheckSum="-574183082" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[tm_GetTransactionSet2]
(
  @firstDay   DATE,
  @lastDay    DATE,  -- Не включает
  @startTime  TIME,
  @finishTime TIME,
  @firstWorkHour int
)
AS

DECLARE
  @first DATETIME,
  @last  DATETIME,
  @start  TIME,
  @finish TIME
BEGIN

  IF @firstDay IS NULL
    SET @first = '1900-01-01';
  ELSE
	SET @first = DATEADD(hh, @firstWorkHour, CAST(@firstDay AS DATETIME));

  IF @lastDay IS NULL
    SET @last = '2100-01-01';
  ELSE
	SET @last = DATEADD(hh, @firstWorkHour, CAST(@lastDay AS DATETIME));

  IF @startTime IS NULL
    SET @start = '00:00:00';
  ELSE
	SET @start = @startTime;

  IF @finishTime IS NULL
    SET @finish = '23:59:59.997';
  ELSE
	SET @finish = @finishTime;

SELECT
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE) AS WorkDay,
	fcs_DataLoading.TransactionSourceID,
	fcs_VehicleTrip.LineID,
	COUNT(*) AS Transactions
FROM
	fcs_Transaction
LEFT OUTER JOIN
   fcs_DataLoading ON fcs_DataLoading.ID = fcs_Transaction.TransactionLoadingID
LEFT OUTER JOIN
	fcs_VehicleTrip ON fcs_VehicleTrip.ID = fcs_Transaction.VehicleTripID
WHERE
	fcs_Transaction.[Date] BETWEEN @first AND @last
  AND
	CAST(fcs_Transaction.[Date] AS TIME) BETWEEN @start AND @finish
GROUP BY
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE),
	fcs_DataLoading.TransactionSourceID,
	fcs_VehicleTrip.LineID

END
</Definition>
      <Parameters>
        <ParameterMould Name="@firstDay" MappingName="firstDay" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Date" Definition="date" />
        </ParameterMould>
        <ParameterMould Name="@lastDay" MappingName="lastDay" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Date" Definition="date" />
        </ParameterMould>
        <ParameterMould Name="@startTime" MappingName="startTime" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Time" Definition="time(7)" />
        </ParameterMould>
        <ParameterMould Name="@finishTime" MappingName="finishTime" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="Time" Definition="time(7)" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="tm_GetTransactionSet3" MappingName="GetTransactionSet3" CheckSum="-574183082" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[tm_GetTransactionSet3]
(
  @firstDay   DATE,
  @lastDay    DATE,  -- Не включает
  @startTime  TIME,
  @finishTime TIME,
  @firstWorkHour int
)
AS

DECLARE
  @first DATETIME,
  @last  DATETIME,
  @start  TIME,
  @finish TIME
BEGIN

  IF @firstDay IS NULL
    SET @first = '1900-01-01';
  ELSE
	SET @first = DATEADD(hh, @firstWorkHour, CAST(@firstDay AS DATETIME));

  IF @lastDay IS NULL
    SET @last = '2100-01-01';
  ELSE
	SET @last = DATEADD(hh, @firstWorkHour, CAST(@lastDay AS DATETIME));

  IF @startTime IS NULL
    SET @start = '00:00:00';
  ELSE
	SET @start = @startTime;

  IF @finishTime IS NULL
    SET @finish = '23:59:59.997';
  ELSE
	SET @finish = @finishTime;

SELECT
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE) AS WorkDay,
	fcs_DataLoading.TransactionSourceID,
	LineRouteID,
	StopPointID,
	COUNT(*) AS Transactions
FROM
	fcs_Transaction
LEFT OUTER JOIN
   fcs_DataLoading ON fcs_DataLoading.ID = fcs_Transaction.TransactionLoadingID
LEFT OUTER JOIN
	fcs_VehicleTrip ON fcs_VehicleTrip.ID = fcs_Transaction.VehicleTripID
WHERE
	fcs_Transaction.[Date] BETWEEN @first AND @last
  AND
	CAST(fcs_Transaction.[Date] AS TIME) BETWEEN @start AND @finish
GROUP BY
	CAST(DATEADD(hh, -@firstWorkHour, fcs_Transaction.[Date]) AS DATE),
	fcs_DataLoading.TransactionSourceID,
	LineRouteID,
	StopPointID

END
</Definition>
