      <Definition>
CREATE VIEW [dbo].[ln_TicketKioskView]
AS
SELECT
	ln_TicketKiosk.ID,
	ln_TicketKiosk.Location,
	ln_TicketKiosk.EmployeeCount,
	ln_Duty.Name AS Duty,
	geo_District.Name AS District,
	geo_AddressView.RoadType,
	geo_AddressView.RoadName,
	geo_AddressView.HouseNumber,
	geo_AddressView.Litera,
	geo_AddressView.HouseIndex,
	ln_TicketKiosk.Comment
FROM
	ln_TicketKiosk
LEFT JOIN
	geo_AddressView
ON
	geo_AddressView.ID = ln_TicketKiosk.AddressID
LEFT JOIN
	geo_Address
ON
	geo_Address.ID = ln_TicketKiosk.AddressID
LEFT JOIN
	geo_District
ON
	geo_District.ID = geo_Address.DistrictID
LEFT JOIN
	ln_Duty
ON
	ln_Duty.ID = ln_TicketKiosk.DutyID
</Definition>
    </ViewMould>
