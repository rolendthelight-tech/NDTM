      <Definition>
CREATE VIEW [dbo].[fcs_RawTransactionView]
AS
SELECT
	 dbo.fcs_Transaction.ID,
	 dbo.fcs_Transaction.SmartCardNumber,
	 dbo.fcs_SmartCardType.Code AS SmartCardType,
	 dbo.fcs_SmartCardKind.Code AS SmartCardKind,
	 dbo.fcs_Transaction.Date,
	 dbo.fcs_VehicleTrip.Number AS TripNumber,
	 dbo.fcs_TransactionSourceView.OperatorCode,
	 dbo.fcs_TransactionSourceView.OperatorBranchCode,
	 dbo.ln_Line.Code AS LineCode,
	 dbo.fcs_VehicleTrip.LineWorkOrderNumber,
	 dbo.ln_VehicleUnit.Code AS VehicleTypeCode,
	 dbo.fcs_CheckEmployee.ClockNumber AS ConductorClockNumber,
	 dbo.rms_Document.Number AS EquipmentNumber,
	 dbo.ln_VehicleUnit.StateNumber,
	 dbo.ln_VehicleUnit.HullNumber,
	 dbo.fcs_Transaction.Hash,
	 dbo.fcs_Equipment.Type AS EquipmentType,
	 dbo.fcs_DataLoading.TransactionSourceID,
	 dbo.fcs_DataLoading.ProcessedFilePath
FROM
	dbo.fcs_Transaction
LEFT OUTER JOIN
    dbo.fcs_SmartCardKind ON dbo.fcs_SmartCardKind.ID = dbo.fcs_Transaction.SmartCardKindID
LEFT OUTER JOIN
    dbo.fcs_SmartCardType ON dbo.fcs_SmartCardType.ID = dbo.fcs_SmartCardKind.SmartCardTypeID
LEFT OUTER JOIN
	dbo.fcs_VehicleTrip ON dbo.fcs_VehicleTrip.ID = dbo.fcs_Transaction.VehicleTripID
LEFT OUTER JOIN
   dbo.ln_Line ON dbo.fcs_VehicleTrip.LineID = dbo.ln_Line.ID
LEFT OUTER JOIN
   dbo.ln_VehicleUnit ON dbo.ln_VehicleUnit.ID = dbo.fcs_VehicleTrip.VehicleUnitID
LEFT OUTER JOIN
	dbo.fcs_CheckEmployee ON dbo.fcs_CheckEmployee.ID = dbo.fcs_Transaction.CheckEmployeeID
LEFT OUTER JOIN
   dbo.fcs_DataLoading ON dbo.fcs_DataLoading.ID = fcs_Transaction.TransactionLoadingID
LEFT OUTER JOIN
   dbo.fcs_TransactionSourceView ON dbo.fcs_TransactionSourceView.ID = dbo.fcs_DataLoading.TransactionSourceID
LEFT OUTER JOIN
	dbo.fcs_Equipment ON dbo.fcs_Equipment.ID = dbo.fcs_Transaction.EquipmentID
LEFT OUTER JOIN
	dbo.rms_Document ON dbo.rms_Document.ID = dbo.fcs_Equipment.ID
</Definition>
    </ViewMould>
    <ViewMould Name="fcs_ReportEquipmentCountView" MappingName="ReportEquipmentCountView" CheckSum="387849627" Schema="dbo">
      <Columns>
        <ColumnMould Name="OperatorShortName" MappingName="OperatorShortName" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(16)" Length="16" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="BranchShortName" MappingName="BranchShortName" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(16)" Length="16" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="BoardEquipmentCount" MappingName="BoardEquipmentCount" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="HandControllerCount" MappingName="HandControllerCount" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[fcs_ReportEquipmentCountView]
AS
SELECT	b.OperatorShortName,
				b.BranchShortName,
				BoardEquipmentCount,
				HandControllerCount
FROM (
	SELECT
		o.OperatorShortName,
		o.BranchShortName,
		COUNT(b.ID) AS BoardEquipmentCount
	FROM fcs_EquipedOperatorBranchListView o
		LEFT JOIN [fcs_BoardEquipmentView] b
			ON o.OperatorShortName = b.OperatorShortName
				AND o.BranchShortName = b.OperatorBranchShortName
	GROUP BY	o.OperatorShortName,
						o.BranchShortName
		) b
JOIN (
	SELECT
		o.OperatorShortName,
		o.BranchShortName,
		COUNT(h.ID) AS HandControllerCount--,
	FROM fcs_EquipedOperatorBranchListView o
		LEFT JOIN [fcs_HandControllerView] h
			ON o.OperatorShortName = h.OperatorShortName
				AND o.BranchShortName = h.OperatorBranchShortName
	GROUP BY	o.OperatorShortName,
						o.BranchShortName
		) h
		ON b.OperatorShortName = h.OperatorShortName
			AND b.BranchShortName = h.BranchShortName
			OR (b.BranchShortName IS NULL AND b.OperatorShortName=h.OperatorShortName)
</Definition>
    </ViewMould>
