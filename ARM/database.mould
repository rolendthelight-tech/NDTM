CREATE VIEW [dbo].[rms_CorrespondenceView]
AS
SELECT     dbo.rms_DocumentView.*,
           dbo.ci_GetEmployeeName(dbo.rms_Correspondence.ResponseEmployeeID) AS ResponseEmployee,
           dbo.rms_Correspondence.DateOfPerformance,
           dbo.rms_Correspondence.IncomingNumber,
           dbo.rms_Correspondence.SendDate,
           dbo.rms_Correspondence.RecieveDate,
           dbo.rms_Correspondence.FileEntryID

FROM       dbo.rms_Correspondence
           LEFT OUTER JOIN dbo.rms_DocumentView ON dbo.rms_Correspondence.ID = dbo.rms_DocumentView.ID
</Definition>
