CREATE VIEW [dbo].[tic_StopSignView]
AS
SELECT
	ln_StopSignView.*,
	dbo.tic_GetStopSignChecksCount(ln_StopSignView.ID) AS ChecksCount,
	dbo.tic_GetStopSignWorkChecksCount(ln_StopSignView.ID) AS WorkChecksCount,
	dbo.tic_GetStopSignDemandsCount(ln_StopSignView.ID) AS DemandsCount
FROM
	ln_StopSignView
</Definition>
