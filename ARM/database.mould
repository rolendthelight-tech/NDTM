        <ColumnMould Name="ID" MappingName="ID" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="PersonType" MappingName="PersonType" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Byte" Definition="tinyint" />
        </ColumnMould>
        <ColumnMould Name="Name" MappingName="Name" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(101)" Length="101" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW ci_PersonView
AS
SELECT
	ci_Person.ID,
	ci_Person.PersonType,
	(CASE ci_Person.PersonType WHEN 0 THEN dbo.ci_GetInitials(ci_Man.Name, ci_Man.Patronimic, ci_Man.Surname)
	WHEN 1 THEN ci_OrganizationView.Form + ' ' + ci_OrganizationView.Name END) AS Name
FROM
	ci_Person
LEFT OUTER JOIN
	ci_Man
ON ci_Man.ID = ci_Person.ID
LEFT OUTER JOIN
	ci_OrganizationView
ON
	ci_OrganizationView.ID = ci_Person.ID
</Definition>
    </ViewMould>
