    <FunctionMould Name="ln_GetLineOperatorString" MappingName="GetLineOperatorString" CheckSum="2048209441" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@lineID" MappingName="lineID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[ln_GetLineOperatorString]
(
	@lineID int
)
RETURNS nvarchar(1024)
AS
BEGIN
	DECLARE @ret nvarchar(1024)

	SELECT @ret = ''

	SELECT
		@ret = @ret + ', ' + o.ShortName
	FROM
		ln_Operator o
	INNER JOIN
		ln_Line2Operator lo2
	ON
		lo2.OperatorID = o.ID
	WHERE
		lo2.LineID = @lineID;

	IF LEN(@ret)&gt;2
	BEGIN
		RETURN RIGHT(@ret, LEN(@ret)-2);
	END

	RETURN  NULL
END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(1024)" Length="1024" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
