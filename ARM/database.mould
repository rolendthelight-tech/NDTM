CREATE VIEW [dbo].[tm_VehicleUnitLoadView]
AS
SELECT
	tm_VehicleUnitLoad.ID,
	ln_VehicleUnitView.TransportType,
	ln_Line.Number AS LineNumber,
	ln_VehicleUnitView.Operator,
	ln_VehicleUnitView.OperatorBranch,
	ln_VehicleUnitView.HullNumber,
	ln_VehicleUnitView.StateNumber,
	tm_LoadValueView.Name,
	tm_LoadValueView.AnalysisTaskID,
	tm_LoadValueView.FirstDate,
	tm_LoadValueView.LastDate,
	tm_LoadValueView.[WeekDay],
	tm_LoadValueView.StartTime,
	tm_LoadValueView.FinishTime,
	tm_LoadValueView.Samples,
	tm_LoadValueView.Value,
	tm_LoadValueView.Deviation,
	tm_LoadValueView.MinFractile,
	tm_LoadValueView.Median,
	tm_LoadValueView.MaxFractile,
	tm_LoadValueView.CalculationDate

FROM
	tm_VehicleUnitLoad
LEFT OUTER JOIN
    ln_Line
		ON ln_Line.ID = tm_VehicleUnitLoad.LineID
LEFT OUTER JOIN
	ln_VehicleUnitView
		ON ln_VehicleUnitView.ID = tm_VehicleUnitLoad.VehicleUnitID
LEFT OUTER JOIN
	tm_LoadValueView
		ON	tm_LoadValueView.ID = tm_VehicleUnitLoad.LoadValueID
</Definition>
