    <FunctionMould Name="tic_GetStopSignDemandCost" MappingName="GetStopSignDemandCost" CheckSum="237353155" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@stopSignDemandID" MappingName="stopSignDemandID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[tic_GetStopSignDemandCost]
(
	@stopSignDemandID int
)
RETURNS float
AS
BEGIN
	DECLARE @ret float

	SELECT @ret = 0

	SELECT
		@ret = @ret + tic_StopSignWorkType.Price
	FROM
		tic_StopSignWorkType
	INNER JOIN
		tic_StopSignDemand2StopSignWorkType
	ON
		tic_StopSignDemand2StopSignWorkType.StopSignWorkTypeID = tic_StopSignWorkType.ID
	WHERE
		tic_StopSignDemand2StopSignWorkType.StopSignDemandID = @stopSignDemandID

	RETURN @ret
END

</Definition>
      <ReturnType xsi:type="RealTypeMould" DbType="Double" Definition="float" />
    </FunctionMould>
