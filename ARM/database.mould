(
	@stopSignID int
)
RETURNS NVARCHAR(128)
AS
BEGIN

DECLARE @S NVARCHAR(128)
SET @S = ''

;

WITH N(Number, Direction) AS
(
	SELECT DISTINCT dbo.ln_Line.Number AS Number, dbo.ln_Direction.ShortName AS Direction

	FROM dbo.ln_LineRoute
		 INNER JOIN dbo.ln_Direction ON dbo.ln_LineRoute.DirectionID = dbo.ln_Direction.ID
		 INNER JOIN dbo.ln_Line ON dbo.ln_LineRoute.LineID = dbo.ln_Line.ID
		 INNER JOIN dbo.ln_LineRoute2StopSign ON dbo.ln_LineRoute2StopSign.LineRouteID = dbo.ln_LineRoute.ID
	WHERE
		dbo.ln_LineRoute2StopSign.StopSignID = @stopSignID
)

SELECT @S = @S + Number + '(' + Direction + ')' + ' ' FROM N
RETURN dbo.aux_EmptyString2Null(@S)

END
</Definition>
