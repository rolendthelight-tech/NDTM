      <Definition>
CREATE VIEW [dbo].[map_ViewPredicateView]
AS
SELECT
	dbo.map_ViewPredicate.ID,
	dbo.map_ViewPredicate.OrderNumber,
	dbo.map_Layer.Name AS LayerName,
	dbo.map_Style.StyleString,
	dbo.map_ViewPredicate.FilterString,
	dbo.map_ViewProfile.Name AS ProfileName
FROM
	dbo.map_ViewPredicate
LEFT OUTER JOIN
	dbo.map_ViewProfileItem
ON
	dbo.map_ViewProfileItem.ID = dbo.map_ViewPredicate.ViewProfileItemID
LEFT OUTER JOIN
	dbo.map_Layer
ON
	dbo.map_ViewProfileItem.LayerID = dbo.map_Layer.ID
LEFT OUTER JOIN
	dbo.map_ViewProfile
ON
	dbo.map_ViewProfileItem.ViewProfileID = dbo.map_ViewProfile.ID
LEFT OUTER JOIN
	dbo.map_Style
ON
	dbo.map_Style.ID = dbo.map_ViewPredicate.StyleID
</Definition>
    </ViewMould>
