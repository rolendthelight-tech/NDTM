CREATE VIEW [dbo].[sec_UserRoleView]
AS
SELECT   
 dbo.sec_User.ID,
 dbo.rms_Employee.Surname,
 dbo.rms_Employee.Name,
 dbo.rms_Employee.Patronimic, 
 dbo.sec_User.Login,
 dbo.sec_GetRoleNames(dbo.sec_User.Login) AS RoleNames
 
FROM
	dbo.sec_User
LEFT OUTER JOIN
	dbo.rms_Employee
		ON dbo.sec_User.ID = dbo.rms_Employee.UserID
 
</Definition>
    </ViewMould>
