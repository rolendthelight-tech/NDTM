CREATE VIEW [dbo].[tic_StopSignCheckView]
AS
SELECT
		dbo.tic_StopSignCheck.ID,
		dbo.tic_StopSignCheck.PlanPerformanceDate,
		dbo.tic_StopSignCheck.InspectorID,
		dbo.aux_EmptyString2Null(dbo.rms_DocumentView.Status) AS Status,
		dbo.ln_StopSignView.ID AS StopSignID,
		dbo.ln_StopSignView.Name AS StopSignName,
		dbo.ln_StopSignView.LineRouteString,
		dbo.ln_StopSignView.StopPointNumber,
		dbo.ln_StopSignView.StopPointName,
		dbo.ln_StopSignView.District,
		dbo.ln_StopSignView.Address,
		dbo.ln_StopSignView.Direction,
		dbo.tic_StopSignCheck.PerformanceDate,
		dbo.aux_EmptyString2Null(StopSignStatus.Name) AS StopSignStatus,
		dbo.tic_StopSignFaultType.Name AS StopSignFaultType,
		rms_CorrespondenceView.Name + ' № ' + dbo.rms_CorrespondenceView.IncomingNumber AS Correspondence,
		dbo.ci_GetInitials(dbo.rms_EmployeeView.Name,
		dbo.rms_EmployeeView.Patronimic,
		dbo.rms_EmployeeView.Surname) AS Inspector,
		dbo.rms_DocumentView.ModifiedDate,
		dbo.rms_DocumentView.DataSource,
		dbo.rms_DocumentView.RowColor
FROM
    dbo.tic_StopSignCheck
LEFT OUTER JOIN
	dbo.rms_DocumentView
		ON dbo.rms_DocumentView.ID = dbo.tic_StopSignCheck.ID
LEFT OUTER JOIN
	dbo.ln_StopSignView
		ON dbo.ln_StopSignView.ID = dbo.tic_StopSignCheck.StopSignID
LEFT OUTER JOIN
	dbo.rms_Status AS StopSignStatus
		ON StopSignStatus.ID = dbo.tic_StopSignCheck.StopSignStatusID
LEFT OUTER JOIN
	dbo.tic_StopSignFaultType
		ON dbo.tic_StopSignFaultType.ID = dbo.tic_StopSignCheck.StopSignFaultTypeID
LEFT OUTER JOIN
	dbo.rms_EmployeeView
		ON dbo.rms_EmployeeView.ID = dbo.tic_StopSignCheck.InspectorID
LEFT OUTER JOIN
	rms_CorrespondenceView
		ON rms_CorrespondenceView.ID = tic_StopSignCheck.CorrespondenceID
</Definition>
    </ViewMould>
