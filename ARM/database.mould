    <FunctionMould Name="fcs_GetInvalidFlag" MappingName="GetInvalidFlag" CheckSum="-1306010880" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@statusCode" MappingName="statusCode" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int64" Definition="bigint" />
        </ParameterMould>
      </Parameters>
      <Definition>-- =============================================
-- Author:		&lt;Author,,Name&gt;
-- Create date: &lt;Create Date, ,&gt;
-- Description:	&lt;Description, ,&gt;
-- =============================================
CREATE FUNCTION dbo.fcs_GetInvalidFlag
(
	@statusCode bigint
)
RETURNS int
AS
BEGIN
	-- Declare the return variable here
	DECLARE @result int = 0;
	DECLARE @mask bigint = 0x1FFFFFFFFC000;

	-- Add the T-SQL statements to compute the return value here
	IF @statusCode&amp;(@mask^@mask) &gt; 0
		SELECT @result  = 2;

	-- Return the result of the function
	RETURN @result;

END
</Definition>
      <ReturnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
    </FunctionMould>
