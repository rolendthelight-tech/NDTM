    <ViewMould Name="rn_CrossRoadView" MappingName="CrossRoadView" CheckSum="2043431238" Schema="dbo">
      <Columns>
        <ColumnMould Name="NodeId" MappingName="NodeId" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="RoadCount" MappingName="RoadCount" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[rn_CrossRoadView]
AS
SELECT ID AS NodeId, COUNT(*) AS RoadCount FROM
(
	SELECT
		[rn_Node].ID,
		RoadId
	FROM
		[rn_Node]
	LEFT JOIN rn_RoadSegment
		ON rn_RoadSegment.FromNodeID = [rn_Node].ID
		OR rn_RoadSegment.ToNodeID = [rn_Node].ID
	WHERE
		RoadId IS NOT NULL
) AS [INNER]
GROUP BY ID
HAVING COUNT(*) &gt; 1
</Definition>
    </ViewMould>
