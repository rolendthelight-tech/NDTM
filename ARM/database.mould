CREATE VIEW [dbo].[fcs_TransactionLoadReportBaseView]
AS
SELECT
	dbo.fcs_TransactionLoadReport.ID,
	dbo.fcs_TransactionLoadReport.SendDate,
	dbo.fcs_TransactionLoadReport.StartDate,
	dbo.fcs_TransactionLoadReport.EndDate,
	dbo.fcs_TransactionSource.FtpSourceFolder,
	dbo.fcs_TransactionSource.FtpBackupFolder,
	dbo.fcs_TransactionSource.FtpDestinationFolder,
	dbo.fcs_TransactionSource.Email,
	dbo.fcs_TransactionSource.Password,
	dbo.ln_Operator.Code As OperatorCode,
	dbo.ln_Operator.Name As OperatorName,
	dbo.ln_Operator.OrganizationID As OperatorOrganizationID,
	dbo.ln_Operator.ShortName As OperatorShortName,
	dbo.ln_OperatorBranch.Code As OperatorBranchCode,
	dbo.ln_OperatorBranch.Name As OperatorBranchName,
	dbo.ln_OperatorBranch.OperatorID As OperatorBranchOperatorID,
	dbo.ln_OperatorBranch.ShortName As OperatorBranchShortName,
	dbo.cor_FileEntry.FileDataGuid,
	dbo.cor_FileEntry.Name,
	dbo.cor_FileData.Data
  FROM dbo.fcs_TransactionLoadReport
INNER JOIN
	dbo.fcs_TransactionSource
	ON dbo.fcs_TransactionSource.ID = dbo.fcs_TransactionLoadReport.TransactionSourceID
INNER JOIN
	dbo.cor_FileEntry
	ON dbo.cor_FileEntry.ID = dbo.fcs_TransactionLoadReport.FileEntryID
LEFT OUTER JOIN
	dbo.ln_Operator
	ON dbo.fcs_TransactionSource.OperatorID = dbo.ln_Operator.ID
LEFT OUTER JOIN
	dbo.ln_OperatorBranch
	ON dbo.fcs_TransactionSource.OperatorBranchID = dbo.ln_OperatorBranch.ID
INNER JOIN
	dbo.cor_FileData
	ON dbo.cor_FileData.ObjectGuid = dbo.cor_FileEntry.FileDataGuid
</Definition>
    </ViewMould>
