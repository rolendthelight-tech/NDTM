    <ProcedureMould Name="ln_GetTerminalLines" MappingName="GetTerminalLines" CheckSum="-1699534633" Schema="dbo">
      <Definition>
CREATE PROCEDURE ln_GetTerminalLines
(
	@terminalID int
)
AS
BEGIN
	SELECT
		*
	FROM
		ln_LineView
	WHERE
		EXISTS
		(
			SELECT NULL AS [Empty]
			FROM
				ln_LineRoute
			WHERE
				ln_LineView.ID = ln_LineRoute.LineID
			AND
				(
					ln_LineRoute.BeginTerminalID = @terminalID
					OR
					ln_LineRoute.EndTerminalID = @terminalID
				)
		)

END
</Definition>
      <Parameters>
        <ParameterMould Name="@terminalID" MappingName="terminalID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
