CREATE FUNCTION [dbo].[ln_GetLineRouteStopPointString]
(
	@stopPointID int
)
RETURNS NVARCHAR(128)
AS
BEGIN

DECLARE @S NVARCHAR(128)
SET @S = ''

;

WITH N(TransportType, Number, Direction) AS
(
	SELECT DISTINCT dbo.ln_Line.TransportType AS TransportType, dbo.ln_Line.Number AS Number, dbo.ln_Direction.ShortName AS Direction

	FROM dbo.ln_LineRoute
		 INNER JOIN dbo.ln_Direction ON dbo.ln_LineRoute.DirectionID = dbo.ln_Direction.ID
		 INNER JOIN dbo.ln_Line ON dbo.ln_LineRoute.LineID = dbo.ln_Line.ID

	WHERE dbo.ln_LineRoute.IsActive = 1 AND dbo.ln_LineRoute.ID IN
	(
		SELECT dbo.ln_LineRoute.ID

		FROM   dbo.ln_LineRoute
			   INNER JOIN ln_LineRoute2StopPoint ON ln_LineRoute.ID = ln_LineRoute2StopPoint.LineRouteID

		WHERE  ln_LineRoute2StopPoint.StopPointID = @stopPointID
	)

)

SELECT @S = @S + dbo.ln_GetTransportTypeShortName(TransportType) + Number + '(' + Direction + ')' + ' ' FROM N

RETURN dbo.aux_EmptyString2Null(@S)

END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(128)" Length="128" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
