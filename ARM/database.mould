      <Definition>
CREATE VIEW [dbo].[ci_ManView]
AS
SELECT
	ci_Man.ID,
	ci_Man.Surname,
	ci_Man.Name,
	ci_Man.Patronimic,
	ci_Man.Gender,
	ci_Man.NPR,
	ci_Passport.DateOfBirth,
	ci_Passport.Series,
	ci_Passport.Number,
	geo_AddressView.PostalCode,
	geo_AddressView.RoadType,
	geo_AddressView.RoadName,
	geo_AddressView.HouseNumber,
	geo_AddressView.HouseIndex,
	geo_AddressView.Litera
FROM
	ci_Man
LEFT JOIN ci_Passport
	ON ci_Passport.ID = ci_Man.PassportID
LEFT JOIN geo_AddressView
	ON geo_AddressView.ID = ci_Man.AddressID
</Definition>
    </ViewMould>
