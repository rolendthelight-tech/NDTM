      <Definition>
CREATE VIEW
	[dbo].[pcc_ControlRevisionCheckView]
AS
SELECT
	pcc_ControlRevisionCheck.Code,
	pcc_CheckType.Name AS CheckType,
	pcc_CheckInitiatorView.IncomingNumber AS InitiatorIncomingNumber,
	pcc_CheckInitiatorView.Correspondence AS InitiatorCorrespondence,
	pcc_CheckInitiatorView.Person AS InitiatorPerson,
	rms_DocumentType.Name AS DemandDocument,
    pcc_ControlRevisionCheck.PerformanceDate,
	ln_Line.TransportType,
	ln_Line.Number AS LineNumber,
	rms_DocumentView.*
FROM
	pcc_ControlRevisionCheck
INNER JOIN
	rms_DocumentView
ON
	pcc_ControlRevisionCheck.ID = rms_DocumentView.ID
LEFT OUTER JOIN
	pcc_CheckType
ON
	pcc_CheckType.ID = pcc_ControlRevisionCheck.CheckTypeID
LEFT OUTER JOIN
	pcc_CheckInitiatorView
ON
	pcc_CheckInitiatorView.ID = pcc_ControlRevisionCheck.CheckInitiatorID
LEFT OUTER JOIN
	rms_DocumentType
ON
	rms_DocumentType.ID = pcc_ControlRevisionCheck.DemandDocumentID
LEFT OUTER JOIN
	ln_Line
ON ln_Line.ID = pcc_ControlRevisionCheck.LineID
</Definition>
