      <Definition>

CREATE VIEW [dbo].[rms_EmployeeView]
AS
SELECT    e.ID,
					e.Surname,
					e.Name,
					e.Patronimic,
					u.[Login],
					d.FullName AS Department,
					p.Name AS Position,
					doc.Status,
					doc.RowColor AS RowColor

FROM         rms_Employee e LEFT OUTER JOIN
                      rms_DocumentView doc ON e.ID = doc.ID LEFT OUTER JOIN
                      sec_User u ON u.ID = e.UserID LEFT OUTER JOIN
                      rms_Position p ON p.ID = e.PositionID LEFT OUTER JOIN
                      rms_Department d ON doc.ID = e.DepartmentID

</Definition>
    </ViewMould>
