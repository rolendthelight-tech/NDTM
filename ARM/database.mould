      <Definition>
CREATE VIEW [dbo].[tm_LoadValueView]
AS
SELECT
	ID,
	Name,
	AnalysisTaskID,
	FirstDate,
	LastDate,
	[WeekDay],
	StartTime,
	FinishTime,
	Samples,
	CONVERT(int, Value) AS Value,
	CONVERT(int, Deviation) AS Deviation,
	CONVERT(int, MinFractile) AS MinFractile,
	CONVERT(int, Median) AS Median,
	CONVERT(int, MaxFractile) AS MaxFractile,
	CalculationDate
FROM
	tm_LoadValue
</Definition>
