      <Definition>
CREATE VIEW [dbo].[ln_OperatorBranchBaseView]
AS
SELECT dbo.ln_OperatorBranch.ID,
       dbo.ln_OperatorBranch.Code,
       dbo.ln_Operator.Name As Operator,
       dbo.ln_Operator.ShortName AS OperatorShortName,
       dbo.ln_OperatorBranch.Name,
       dbo.ln_OperatorBranch.ShortName,
       dbo.cor_Entity.CreatedDate,
       dbo.cor_Entity.ModifiedDate,
       dbo.cor_DataSource.Name As DataSourceName
  FROM dbo.ln_OperatorBranch
INNER JOIN
    dbo.cor_Entity
    ON dbo.cor_Entity.ID = dbo.ln_OperatorBranch.ID
LEFT OUTER JOIN
    dbo.cor_DataSource
    ON dbo.cor_DataSource.ID = dbo.cor_Entity.DataSourceID
LEFT OUTER JOIN
	dbo.ln_Operator
	ON dbo.ln_Operator.ID = dbo.ln_OperatorBranch.OperatorID
</Definition>
    </ViewMould>
