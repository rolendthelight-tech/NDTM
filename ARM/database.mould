      <Definition>
CREATE VIEW [dbo].[ln_TerminalView]
AS
SELECT
	ln_Terminal.ID,
	CONVERT(tinyint, CASE (cor_Entity.TableName)
		WHEN 'ln_TurnRing' THEN 0
		WHEN 'ln_DispatcherStation' THEN 1
		WHEN 'ln_VehicleUnitFleet' THEN 2
		END) AS TerminalType,
	ln_Terminal.Name,
	geo_AddressView.RoadType,
	geo_AddressView.RoadName,
	geo_AddressView.HouseNumber,
	geo_AddressView.Litera,
	geo_AddressView.HouseIndex,
	rms_Document.Comment,
	rms_Status.RowColor
FROM
	dbo.ln_Terminal
INNER JOIN
	dbo.rms_Document
ON
	dbo.ln_Terminal.ID = dbo.rms_Document.ID
INNER JOIN
	cor_Entity
ON
	cor_Entity.ID = dbo.rms_Document.ID
LEFT OUTER JOIN
	dbo.geo_AddressView
ON
	dbo.ln_Terminal.AddressID = dbo.geo_AddressView.ID
LEFT OUTER JOIN
	rms_Status
ON
	rms_Status.ID = rms_Document.StatusID
</Definition>
    </ViewMould>
