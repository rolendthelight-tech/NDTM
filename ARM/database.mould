CREATE VIEW [dbo].[fcs_SoftwareView]
AS
SELECT
	dbo.fcs_Software.ID,
	dbo.rms_DocumentView.Number,
	dbo.fcs_Software.Name,
	dbo.fcs_Software.[Version],
	(CASE ISNULL(FileDataGuid, '00000000-0000-0000-0000-000000000000')
		WHEN '00000000-0000-0000-0000-000000000000' THEN CONVERT(bit, 0) ELSE CONVERT(bit, 1) END) AS HasFileData,
	dbo.rms_DocumentView.CreatedDate,
	dbo.rms_DocumentView.ModifiedDate,
	dbo.rms_DocumentView.[Status],
	dbo.rms_DocumentView.RowColor
FROM
	dbo.fcs_Software
LEFT JOIN
	dbo.rms_DocumentView ON dbo.rms_DocumentView.ID = dbo.fcs_Software.ID
</Definition>
    </ViewMould>
