CREATE VIEW [dbo].[tic_StopSignWorkCheckView]
AS
SELECT
	tic_StopSignWorkCheck.ID,
	tic_StopSignWorkCheck.PlanPerformanceDate,
	tic_StopSignWorkType.Name AS WorkType,
	rms_DocumentView.Status,
	ln_StopSignView.ID AS StopSignID,
	ln_StopSignView.LineRouteString,
	ln_StopSignView.StopPointNumber,
	ln_StopSignView.StopPointName,
	ln_StopSignView.District,
	ln_StopSignView.Address,
	ln_StopSignView.Direction,
	tic_StopSignWorkCheck.PerformanceDate,
	StopSignWorkStatus.Name AS StopSignWorkStatus,
	dbo.ci_GetInitials(dbo.rms_EmployeeView.Name, rms_EmployeeView.Patronimic, rms_EmployeeView.Surname) AS Inspector,
	rms_DocumentView.ModifiedDate,
	rms_DocumentView.Comment,
	rms_DocumentView.DataSource,
	rms_DocumentView.RowColor

FROM
	dbo.tic_StopSignWorkCheck
LEFT OUTER JOIN
	dbo.rms_DocumentView
		ON dbo.rms_DocumentView.ID = dbo.tic_StopSignWorkCheck.ID
LEFT OUTER JOIN
	dbo.tic_StopSignWorkType
		ON dbo.tic_StopSignWorkType.ID = dbo.tic_StopSignWorkCheck.StopSignWorkTypeID
LEFT OUTER JOIN
	dbo.ln_StopSignView
		ON dbo.ln_StopSignView.ID = dbo.tic_StopSignWorkCheck.StopSignID
LEFT OUTER JOIN
	dbo.rms_Status AS StopSignWorkStatus
		ON StopSignWorkStatus.ID = dbo.tic_StopSignWorkCheck.StopSignWorkStatusID
LEFT OUTER JOIN
	dbo.rms_EmployeeView ON dbo.rms_EmployeeView.ID = dbo.tic_StopSignWorkCheck.InspectorID
</Definition>
    </ViewMould>
