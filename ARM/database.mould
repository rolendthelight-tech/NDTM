    <ProcedureMould Name="fcs_CheckReusingSmartCardOnMultipleVehicles" MappingName="CheckReusingSmartCardOnMultipleVehicles" CheckSum="1858048463" Schema="dbo">
      <Definition>

CREATE PROCEDURE [dbo].[fcs_CheckReusingSmartCardOnMultipleVehicles]
(
	@login nvarchar(50) = NULL,
	@startDate datetime,
	@endDate datetime,
	@readOnlyFlag int,
	@reusedSmartCardOnMultipleVehicles bigint,
	@interval int = 3
)
AS
BEGIN


SELECT DISTINCT v.ID
INTO #vehicleTrips
FROM fcs_VehicleTrip v
WHERE v.FirstTransactionDate
	BETWEEN @startDate AND @endDate;

UPDATE fcs_Transaction 
SET 
	StatusCode = (ISNULL(StatusCode, 0) | @reusedSmartCardOnMultipleVehicles),
	Flags = (ISNULL(Flags, 0)
						| dbo.fcs_GetInvalidFlag(ISNULL(StatusCode, 0) | @reusedSmartCardOnMultipleVehicles)),
	[Login] = @login,
	ModifiedDate = GETDATE()
WHERE	ID IN	(
	SELECT
				t1.ID
	FROM (
		SELECT
			t.ID,
			t.[Date],
			t.SmartCardNumber,
			t.VehicleTripID
		FROM fcs_Transaction t
		JOIN #vehicleTrips v
		 ON t.VehicleTripID = v.ID
		WHERE (t.Flags &amp; @readOnlyFlag) = 0
	) t1
	JOIN (
		SELECT
			t.ID,
			t.[Date],
			t.SmartCardNumber,
			t.VehicleTripID
		FROM fcs_Transaction t
		JOIN #vehicleTrips v
		 ON t.VehicleTripID = v.ID
		WHERE (t.Flags &amp; @readOnlyFlag) = 0
	) t2
		ON t1.SmartCardNumber=t2.SmartCardNumber
		WHERE t1.VehicleTripID != t2.VehicleTripID
			AND ABS(DATEDIFF(minute, t1.[Date], t2.[Date]))&lt; @interval
	)

DECLARE @rowCount bigint = @@ROWCOUNT;

DROP TABLE #vehicleTrips;

SELECT 'RowCount' = @rowCount;

END

</Definition>
      <Parameters>
        <ParameterMould Name="@login" MappingName="login" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@readOnlyFlag" MappingName="readOnlyFlag" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@reusedSmartCardOnMultipleVehicles" MappingName="reusedSmartCardOnMultipleVehicles" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int64" Definition="bigint" />
        </ParameterMould>
        <ParameterMould Name="@interval" MappingName="interval" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_CheckTransactionIdlePeriod" MappingName="CheckTransactionIdlePeriod" CheckSum="793874336" Schema="dbo">
      <Definition>
CREATE PROCEDURE fcs_CheckTransactionIdlePeriod
	@checkPeriod datetime
AS
BEGIN
	SET NOCOUNT ON;

	DECLARE @idlePeriod datetime = GETDATE() - (
		SELECT MAX(d.FtpUploadDate)
		FROM fcs_DataLoading d
			JOIN fcs_TransactionLoading t
				ON d.ID = t.ID
		);

	IF @checkPeriod &lt; @idlePeriod
	BEGIN
		SELECT 'IdlePeriod' =  @idlePeriod;
	END


END
</Definition>
      <Parameters>
        <ParameterMould Name="@checkPeriod" MappingName="checkPeriod" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_CheckVehicleIssueIdlePeriod" MappingName="CheckVehicleIssueIdlePeriod" CheckSum="793874336" Schema="dbo">
      <Definition>
CREATE PROCEDURE fcs_CheckVehicleIssueIdlePeriod
	@checkPeriod datetime
AS
BEGIN
	SET NOCOUNT ON;

	DECLARE @idlePeriod datetime = GETDATE() - (
		SELECT MAX(d.FtpUploadDate)
		FROM fcs_DataLoading d
			JOIN fcs_TransactionLoading tl
				ON d.ID = tl.ID
			JOIN fcs_VehicleTrip vt
				ON vt.TransactionLoadingID = tl.ID
			JOIN fcs_VehicleIssue i
				ON vt.VehicleIssueID =i.ID
		);

	IF @checkPeriod &lt; @idlePeriod
	BEGIN
		SELECT 'IdlePeriod' =  @idlePeriod;
	END


END
</Definition>
      <Parameters>
        <ParameterMould Name="@checkPeriod" MappingName="checkPeriod" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
