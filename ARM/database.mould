(
	@roadSide tinyint
)
RETURNS NVARCHAR(16)
AS
BEGIN

  DECLARE @string NVARCHAR(16)

  SELECT @string =
    CASE @roadSide
      WHEN 0 THEN 'чётн. ст.'
      WHEN 1 THEN 'нечётн. ст.'
      ELSE NULL
    END

  RETURN @string

END
</Definition>
