CREATE VIEW [dbo].[tm_LineLoadView]
AS
SELECT
	dbo.tm_LineLoad.ID,
	dbo.ln_LineView.TransportType,
	dbo.ln_LineView.Number,
	dbo.fcs_TransactionSourceView.Operator,
	dbo.fcs_TransactionSourceView.OperatorBranch,
	dbo.tm_LoadValueView.Name,
	dbo.tm_LoadValueView.AnalysisTaskID,
	dbo.tm_LoadValueView.FirstDate,
	dbo.tm_LoadValueView.LastDate,
	dbo.tm_LoadValueView.[WeekDay],
	dbo.tm_LoadValueView.StartTime,
	dbo.tm_LoadValueView.FinishTime,
	dbo.tm_LoadValueView.Samples,
	dbo.tm_LoadValueView.Value,
	dbo.tm_LoadValueView.Deviation,
	dbo.tm_LoadValueView.MinFractile,
	dbo.tm_LoadValueView.Median,
	dbo.tm_LoadValueView.MaxFractile,
	dbo.tm_LoadValueView.CalculationDate

FROM
	dbo.tm_LineLoad
LEFT OUTER JOIN
	dbo.ln_LineView
		ON dbo.ln_LineView.ID = dbo.tm_LineLoad.LineID
LEFT OUTER JOIN
	dbo.fcs_TransactionSourceView
		ON dbo.fcs_TransactionSourceView.ID = dbo.tm_LineLoad.TransactionSourceID
LEFT OUTER JOIN
	dbo.tm_LoadValueView
		ON	dbo.tm_LoadValueView.ID = dbo.tm_LineLoad.LoadValueID
</Definition>
    </ViewMould>
