CREATE VIEW [dbo].[tm_VehicleTrackBaseView]
AS
SELECT
	dbo.tm_VehicleTrack.ID,
	dbo.tm_VehicleTrack.LoadDate,
	dbo.tm_VehicleTrack.DepartureDate,
	dbo.tm_VehicleTrack.ArriveDate,
	dbo.tm_VehicleTrack.Duration,
	dbo.tm_VehicleTrack.TrackLength,
	dbo.rms_Status.RowColor,
	dbo.ln_VehicleUnit.Code As VehicleUnitCode,
	dbo.ln_VehicleUnit.StateNumber,
	dbo.ln_VehicleUnit.HullNumber,
	dbo.ln_VehicleUnit.VehicleTypeID,
	dbo.ln_VehicleUnit.CardNumber,
	dbo.ln_VehicleUnit.InUse,
	dbo.cor_Entity.TableName,
	dbo.cor_Entity.CreatedDate,
	dbo.cor_Entity.ModifiedDate,
	dbo.cor_Entity.DataSourceID,
	dbo.ln_Operator.Code As OperatorCode,
	dbo.ln_Operator.Name As OperatorName,
	dbo.ln_Operator.OrganizationID As OperatorOrganizationID,
	dbo.ln_Operator.ShortName As OperatorShortName,
	dbo.ln_OperatorBranch.Code As OperatorBranchCode,
	dbo.ln_OperatorBranch.Name As OperatorBranchName,
	dbo.ln_OperatorBranch.OperatorID As OperatorBranchOperatorID,
	dbo.ln_OperatorBranch.ShortName As OperatorBranchShortName,
	dbo.ln_VehicleType.Name As VehicleTypeName,
	dbo.ln_VehicleType.IsElectric,
	dbo.ln_VehicleType.SeatCapability,
	dbo.ln_VehicleType.TotalCapability,
	dbo.ln_VehicleType.TransportType
  FROM dbo.tm_VehicleTrack
INNER JOIN
	dbo.ln_VehicleUnit
	ON dbo.ln_VehicleUnit.ID = dbo.tm_VehicleTrack.StatusID
INNER JOIN
	dbo.cor_Entity
	ON dbo.cor_Entity.ID = dbo.tm_VehicleTrack.ID
LEFT OUTER JOIN
	dbo.rms_Status
	ON dbo.tm_VehicleTrack.StatusID = dbo.rms_Status.ID
LEFT OUTER JOIN
	dbo.ln_Operator
	ON dbo.ln_VehicleUnit.OperatorID = dbo.ln_Operator.ID
LEFT OUTER JOIN
	dbo.ln_OperatorBranch
	ON dbo.ln_VehicleUnit.OperatorBranchID = dbo.ln_OperatorBranch.ID
LEFT OUTER JOIN
	dbo.ln_VehicleType
	ON dbo.ln_VehicleUnit.VehicleTypeID = dbo.ln_VehicleType.ID
</Definition>
