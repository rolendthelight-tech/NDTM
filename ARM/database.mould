CREATE VIEW [dbo].[fcs_VehicleIssueView]
AS
SELECT
	 fcs_VehicleIssue.ID,
	 rms_DocumentView.Number,
	 fcs_VehicleIssue.StartWorkDate,
	 fcs_VehicleIssue.FinishWorkDate,
	 ln_LineView.TransportType,
	 ln_LineView.Number AS LineNumber,
	 fcs_VehicleIssue.RecieveLineWorkOrder,
	 fcs_VehicleIssue.TransactionUploadDate,
	 fcs_VehicleIssue.MaxTrip,
	 fcs_TransactionSourceView.Operator,
	 fcs_TransactionSourceView.OperatorBranch,
	 fcs_VehicleIssue.HullNumber,
	 ln_VehicleUnit.StateNumber,
	 rms_DocumentView.CreatedDate,
	 rms_DocumentView.ModifiedDate,
	 rms_DocumentView.RowColor
FROM
	dbo.fcs_VehicleIssue
LEFT OUTER JOIN
	dbo.ln_LineView ON dbo.ln_LineView.ID = dbo.fcs_VehicleIssue.LineID
LEFT OUTER JOIN
	dbo.ln_VehicleUnit ON dbo.ln_VehicleUnit.ID = dbo.fcs_VehicleIssue.VehicleUnitID
LEFT OUTER JOIN
	dbo.fcs_TransactionSourceView ON dbo.fcs_TransactionSourceView.ID = dbo.fcs_VehicleIssue.TransactionSourceID
LEFT OUTER JOIN
	dbo.rms_DocumentView ON dbo.rms_DocumentView.ID = dbo.fcs_VehicleIssue.ID
</Definition>
    </ViewMould>
