	dbo.ci_GetEmployeeName(dbo.pcc_FinanceDisciplineControl.Controler1ID) AS Controler1,
	dbo.ci_GetEmployeeName(dbo.pcc_FinanceDisciplineControl.Controler2ID) AS Controler2,
	dbo.ci_GetEmployeeName(dbo.pcc_FinanceDisciplineControl.Controler3ID) AS Controler3,
	ln_VehicleUnitFleetView.Name AS VehicleUnitFleet
FROM
  dbo.pcc_FinanceDisciplineControl
INNER JOIN
  dbo.pcc_ViolationType ON dbo.pcc_FinanceDisciplineControl.ViolationTypeID = dbo.pcc_ViolationType.ID
INNER JOIN
  dbo.pcc_CheckType ON dbo.pcc_FinanceDisciplineControl.CheckTypeID = dbo.pcc_CheckType.ID
INNER JOIN
	rms_CorrespondenceView
ON
	rms_CorrespondenceView.ID = pcc_FinanceDisciplineControl.CorrespondenceID
INNER JOIN
	ln_VehicleUnitFleetView
ON
	ln_VehicleUnitFleetView.ID = pcc_FinanceDisciplineControl.VehicleUnitFleetID
</Definition>
