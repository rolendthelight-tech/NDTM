      <Parameters>
        <ParameterMould Name="@number" MappingName="number" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@created_date" MappingName="created_date" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[rms_GetDocumentString]
(
	@number int,
	@created_date datetime
)
RETURNS nvarchar(50)
AS
BEGIN
	RETURN '№ ' + CONVERT(nvarchar(8), @number) + ' от ' + CONVERT(nvarchar(8),@created_date, 4)
END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
    <FunctionMould Name="sec_GetRoleNames" MappingName="GetRoleNames" CheckSum="171296487" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@login" MappingName="login" Direction="Input">
          <ParameterType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(50)" Length="50" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ParameterMould>
      </Parameters>
      <Definition>




CREATE FUNCTION [dbo].[sec_GetRoleNames]
(
	@login nvarchar(50)
)
RETURNS NVARCHAR(512)
AS
BEGIN

DECLARE @S NVARCHAR(512)
SET @S = ''

;

SELECT @S = @S + ', '+ sec_Role.Name
FROM
	sec_Role
INNER JOIN 
	sec_User
		ON sec_User.Login = @login
INNER JOIN
	sec_User2Role
		ON sec_Role.ID = sec_User2Role.RoleID AND sec_User.ID = sec_User2Role.UserID

SET @S = SUBSTRING(@S, 2, LEN(@S))

RETURN dbo.aux_EmptyString2Null(@S)

END




</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(512)" Length="512" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
