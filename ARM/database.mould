      <Definition>CREATE VIEW [dbo].[tm_StopPointLoadView]
AS
SELECT
	dbo.tm_StopPointLoad.ID,
	dbo.ln_StopPointView.Name AS StopPointName,
	dbo.ln_StopPointView.Direction,
	dbo.ln_StopPointView.LineRouteString,
	dbo.ln_GetLineRouteString(dbo.tm_StopPointLoad.LineRouteID) AS LineRoute,
	dbo.tm_LoadValueView.Name,
	dbo.tm_LoadValueView.AnalysisTaskID,
	dbo.tm_LoadValueView.FirstDate,
	dbo.tm_LoadValueView.LastDate,
	dbo.tm_LoadValueView.[WeekDay],
	dbo.tm_LoadValueView.StartTime,
	dbo.tm_LoadValueView.FinishTime,
	dbo.tm_LoadValueView.Samples,
	dbo.tm_LoadValueView.Value,
	dbo.tm_LoadValueView.Deviation,
	dbo.tm_LoadValueView.MinFractile,
	dbo.tm_LoadValueView.Median,
	dbo.tm_LoadValueView.MaxFractile,
	dbo.tm_LoadValueView.CalculationDate

FROM
	dbo.tm_StopPointLoad
LEFT OUTER JOIN
	dbo.ln_StopPointView
		ON dbo.ln_StopPointView.ID = dbo.tm_StopPointLoad.StopPointID
LEFT OUTER JOIN
	dbo.tm_LoadValueView
		ON	dbo.tm_LoadValueView.ID = dbo.tm_StopPointLoad.LoadValueID

</Definition>
    </ViewMould>
