      <Definition>
CREATE VIEW [dbo].[fcs_EquipmentDefectBaseView]
AS
SELECT dbo.fcs_EquipmentDefect.ID,
       dbo.fcs_EquipmentDefect.Name,
       dbo.cor_Entity.CreatedDate,
       dbo.cor_Entity.ModifiedDate,
       dbo.cor_DataSource.Name As DataSourceName
  FROM dbo.fcs_EquipmentDefect
INNER JOIN
    dbo.cor_Entity
    ON dbo.cor_Entity.ID = dbo.fcs_EquipmentDefect.ID
