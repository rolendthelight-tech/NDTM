    <ProcedureMould Name="fcs_Transaction_Delete" MappingName="Transaction_Delete" CheckSum="-1224745567" Schema="dbo">
      <Definition>
CREATE PROCEDURE [fcs_Transaction_Delete]
													@startDate datetime,
													@endDate datetime,
													@firstWorkHour int
AS
BEGIN
	SET NOCOUNT ON;

		DELETE FROM [fcs_Transaction]
		WHERE [Date] BETWEEN DATEADD(HOUR, @firstWorkHour, @startDate) AND DATEADD(HOUR, @firstWorkHour, @endDate)
		RETURN 0;

END
</Definition>
      <Parameters>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
    <ProcedureMould Name="fcs_TransactionLoading_DeleteCascade" MappingName="TransactionLoading_DeleteCascade" CheckSum="-1224745567" Schema="dbo">
      <Definition>
CREATE PROCEDURE [dbo].[fcs_TransactionLoading_DeleteCascade]
													@startDate datetime,
													@endDate datetime,
													@firstWorkHour int
AS
BEGIN
	SET NOCOUNT ON;

		DELETE FROM fcs_DataLoading
		WHERE  ID IN (
			SELECT DISTINCT TransactionLoadingID
			FROM [fcs_Transaction]
			WHERE [Date] BETWEEN DATEADD(HOUR, @firstWorkHour, @startDate) AND DATEADD(HOUR, @firstWorkHour, @endDate))

	RETURN 0;
END
</Definition>
      <Parameters>
        <ParameterMould Name="@startDate" MappingName="startDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@endDate" MappingName="endDate" Direction="Input">
          <ParameterType xsi:type="DateTimeTypeMould" DbType="DateTime" Definition="datetime" />
        </ParameterMould>
        <ParameterMould Name="@firstWorkHour" MappingName="firstWorkHour" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
    </ProcedureMould>
