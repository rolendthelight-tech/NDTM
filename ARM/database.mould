    <FunctionMould Name="ln_GetTransportTypeShortName" MappingName="GetTransportTypeShortName" CheckSum="-160366161" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@TransportType" MappingName="TransportType" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[ln_GetTransportTypeShortName]
(
	@TransportType int
)
RETURNS NVARCHAR(2)
AS
BEGIN

  DECLARE @ShortName NVARCHAR(2)

  SELECT @ShortName =
    CASE @TransportType
      WHEN 0 THEN 'А'
      WHEN 1 THEN 'Т'
      WHEN 2 THEN 'Тм'
      WHEN 3 THEN 'ЭП'
      WHEN 4 THEN 'И'
      WHEN 5 THEN 'ГП'
      WHEN 6 THEN 'К'
      WHEN 7 THEN 'П'
      WHEN 8 THEN 'В'
      WHEN 9 THEN 'М'
      ELSE ''
    END

  RETURN @ShortName

END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(2)" Length="2" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
    <FunctionMould Name="ln_GetTransportTypeStopPointString" MappingName="GetTransportTypeStopPointString" CheckSum="-1311362168" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@stopPointID" MappingName="stopPointID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[ln_GetTransportTypeStopPointString]
(
	@stopPointID int
)
RETURNS NVARCHAR(128)
AS
BEGIN

DECLARE @S NVARCHAR(128)
SET @S = ''

;

WITH N(TransportType) AS
(
	SELECT DISTINCT dbo.ln_Line.TransportType

	FROM dbo.ln_LineRoute
		 INNER JOIN dbo.ln_Line ON dbo.ln_LineRoute.LineID = dbo.ln_Line.ID

	WHERE dbo.ln_LineRoute.IsActive = 1 AND dbo.ln_LineRoute.ID IN
	(
		SELECT dbo.ln_LineRoute.ID

		FROM   dbo.ln_LineRoute
			   INNER JOIN ln_LineRoute2StopPoint ON ln_LineRoute.ID = ln_LineRoute2StopPoint.LineRouteID

		WHERE  ln_LineRoute2StopPoint.StopPointID = @stopPointID
	)
)

SELECT @S = @S + ', ' + dbo.ln_GetTransportTypeShortName(TransportType) FROM N

;

SET @S = SUBSTRING(@S, 2, LEN(@S))

RETURN dbo.aux_EmptyString2Null(@S)

END
</Definition>
      <ReturnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(128)" Length="128" Multiline="false" Collation="Cyrillic_General_CI_AS" />
    </FunctionMould>
    <FunctionMould Name="map_GetLayerPointCount" MappingName="GetLayerPointCount" CheckSum="-1473932103" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@layerID" MappingName="layerID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
        <ParameterMould Name="@geometryType" MappingName="geometryType" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Byte" Definition="tinyint" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION
[dbo].[map_GetLayerPointCount]
(
	@layerID int,
	@geometryType tinyint
)
RETURNS int

AS
BEGIN
	DECLARE @ret int

	IF @geometryType = 0
		SELECT @ret = COUNT(*) FROM map_Entity2GeoPoint WHERE LayerID = @layerID
	ELSE IF (@geometryType = 1)
		SELECT @ret = COUNT(*) FROM map_PolylinePoint WHERE EXISTS
		(
			SELECT
				NULL AS [Empty]
			FROM
				map_Entity2Polyline
			WHERE
				map_Entity2Polyline.LayerID = @layerID
			AND
				map_Entity2Polyline.PolylineID = map_PolylinePoint.PolylineID
		)

	RETURN @ret
END
</Definition>
      <ReturnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
    </FunctionMould>
    <FunctionMould Name="pcc_GetFinanceChecksCount" MappingName="GetFinanceChecksCount" CheckSum="909674271" Schema="dbo">
      <Parameters>
        <ParameterMould Name="@pcc_WarrantID" MappingName="pcc_WarrantID" Direction="Input">
          <ParameterType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ParameterMould>
      </Parameters>
      <Definition>
CREATE FUNCTION [dbo].[pcc_GetFinanceChecksCount]
(
	@pcc_WarrantID int
)
RETURNS int
AS
BEGIN

	DECLARE @ret int

	SET @ret = 0

	SELECT @ret = COUNT(*) FROM dbo.pcc_FinanceCheck
	WHERE dbo.pcc_FinanceCheck.WarrantID = @pcc_WarrantID

	RETURN @ret

END
