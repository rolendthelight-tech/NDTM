      <Definition>
CREATE VIEW [dbo].[ln_InfoFieldTypeView]
AS
SELECT
	dbo.ln_InfoFieldType.ID,
	dbo.ln_InfoFieldType.Code,
	dbo.ln_InfoFieldType.Width,
	dbo.ln_InfoFieldType.Height,
	dbo.ln_InfoFieldType.Info,
	(CASE ISNULL(ln_StopSignType.Code, '') WHEN '' THEN '' ELSE ln_StopSignType.Code + '. ' END
	+ ISNULL(ln_StopSignType.Name, '')) as SignType
FROM dbo.ln_InfoFieldType
LEFT OUTER JOIN dbo.ln_StopSignType
	ON dbo.ln_InfoFieldType.SignTypeID =  dbo.ln_StopSignType.ID
</Definition>
    </ViewMould>
