      <Definition>
CREATE VIEW [dbo].[ln_StopPointNameBaseView]
AS
SELECT dbo.ln_StopPointName.ID,
       dbo.ln_StopPointName.TransportType,
       dbo.ln_StopPointName.LineNumber,
       dbo.ln_StopPointName.Name,
       dbo.ln_StopPointName.ForwardOrderNumber,
       dbo.ln_StopPointName.BackwardOrderNumber,
       dbo.ln_StopPointName.Comment,
       dbo.cor_Entity.CreatedDate,
       dbo.cor_Entity.ModifiedDate,
       dbo.cor_DataSource.Name As DataSourceName
  FROM dbo.ln_StopPointName
INNER JOIN
    dbo.cor_Entity
    ON dbo.cor_Entity.ID = dbo.ln_StopPointName.ID
LEFT OUTER JOIN
    dbo.cor_DataSource
    ON dbo.cor_DataSource.ID = dbo.cor_Entity.DataSourceID
</Definition>
