CREATE VIEW
	[dbo].[ln_StopPoint2LineRouteView]
AS
SELECT
	ln_StopPointBaseView.ID,
	ln_LineRoute2StopPoint.LineRouteID,
	ln_LineRoute2StopPoint.OrderNumber,
	ln_StopPointBaseView.District,
	ln_StopPointBaseView.RoadName,
	ln_StopPointBaseView.Name,
	ln_StopPointName.Name AS StopPointName,
	ln_StopPointBaseView.LineRouteString,
	ln_StopPointBaseView.[Address],
	ln_StopPointBaseView.Direction,
	ln_LineRoute2StopPoint.IsBoard,
	ln_LineRoute2StopPoint.IsAlight,
	dbo.ln_GetStopSignCount(ln_StopPointBaseView.ID) AS SignCount,
	ln_StopPointBaseView.PavilionCount,
	ln_StopPointBaseView.ModifiedDate,
	ln_StopPointBaseView.DataSource
FROM
	ln_StopPointBaseView
INNER JOIN
	ln_LineRoute2StopPoint
ON
	ln_LineRoute2StopPoint.StopPointID = ln_StopPointBaseView.ID
LEFT JOIN
	ln_StopPointName
ON
	ln_StopPointName.ID = ln_LineRoute2StopPoint.StopPointNameID
</Definition>
    </ViewMould>
