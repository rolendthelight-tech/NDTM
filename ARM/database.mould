    <ViewMould Name="rn_TurnView" MappingName="TurnView" CheckSum="-708528489" Schema="dbo">
      <Columns>
        <ColumnMould Name="ID" MappingName="ID" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="FromNode" MappingName="FromNode" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(62)" Length="62" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="ToNode" MappingName="ToNode" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(62)" Length="62" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="ViaNode" MappingName="ViaNode" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(62)" Length="62" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
        <ColumnMould Name="Type" MappingName="Type" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Byte" Definition="tinyint" />
        </ColumnMould>
        <ColumnMould Name="CapacityPrivateTransport" MappingName="CapacityPrivateTransport" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="false">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[rn_TurnView]
AS
SELECT
	rn_Turn.ID,
	CONVERT(nvarchar(10), FromNode.Number)
	+ (CASE ISNULL(FromNode.Name, '') WHEN '' THEN '' ELSE '. ' + FromNode.Name END) AS FromNode,
	CONVERT(nvarchar(10), ToNode.Number)
	+ (CASE ISNULL(ToNode.Name, '') WHEN '' THEN '' ELSE '. ' + ToNode.Name END) AS ToNode,
	CONVERT(nvarchar(10), ViaNode.Number)
	+ (CASE ISNULL(ViaNode.Name, '') WHEN '' THEN '' ELSE '. ' + ViaNode.Name END) AS ViaNode,
	rn_Turn.Type,
	rn_Turn.CapacityPrivateTransport
FROM
	rn_Turn
LEFT JOIN rn_Node AS FromNode
	ON FromNode.ID = rn_Turn.FromNodeID
LEFT JOIN rn_Node AS ToNode
	ON ToNode.ID = rn_Turn.ToNodeID
LEFT JOIN rn_Node AS ViaNode
	ON ViaNode.ID = rn_Turn.ViaNodeID
</Definition>
    </ViewMould>
    <ViewMould Name="sec_TableDescriptionView" MappingName="TableDescriptionView" CheckSum="1427597986" Schema="dbo">
      <Columns>
        <ColumnMould Name="ID" MappingName="ID" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="IntegerTypeMould" DbType="Int32" Definition="int" />
        </ColumnMould>
        <ColumnMould Name="Name" MappingName="Name" ObjectGuid="00000000-0000-0000-0000-000000000000" IsFileStream="false" Mandatory="true">
          <ColumnType xsi:type="StringTypeMould" DbType="String" Definition="nvarchar(128)" Length="128" Multiline="false" Collation="Cyrillic_General_CI_AS" />
        </ColumnMould>
      </Columns>
      <Definition>
CREATE VIEW [dbo].[sec_TableDescriptionView]
AS
SELECT
	sys.objects.object_id AS ID,
	sys.objects.name AS Name
FROM sys.objects
WHERE
	OBJECTPROPERTY(sys.objects.object_id, 'IsUserTable') &lt;&gt; 0 AND
	OBJECTPROPERTY(sys.objects.object_id, 'IsMSShipped') = 0 AND
	sys.objects.name &lt;&gt; 'sysdiagrams' OR
	OBJECTPROPERTY(sys.objects.object_id, 'IsMSShipped') = 0 AND
	sys.objects.name IN ('sec_TableDescriptionView') AND
	sys.objects.name &lt;&gt; 'sysdiagrams'
</Definition>
    </ViewMould>
    <ViewMould Name="sec_UserRoleView" MappingName="UserRoleView" CheckSum="1519531604" Schema="dbo">
