      <Definition>
CREATE VIEW [dbo].[ln_StopPointView]
AS
SELECT
	dbo.ln_StopPointBaseView.ID,
	dbo.ln_StopPointBaseView.Number,
	dbo.ln_StopPointBaseView.District,
	dbo.ln_StopPointBaseView.RoadName,
    dbo.ln_StopPointBaseView.Name,
    dbo.ln_StopPointBaseView.TransportTypeString,
    dbo.ln_StopPointBaseView.LineRouteString,
	dbo.ln_StopPointBaseView.Direction,
	dbo.ln_StopPointBaseView.Address,
    dbo.ln_StopPointBaseView.IsRoadSign516,
    dbo.ln_StopPointBaseView.IsRoadMark,
    dbo.ln_StopPointBaseView.IsBoarding,
	dbo.ln_StopPointBaseView.Status,
	dbo.ln_StopPointBaseView.ActivationDate,
	dbo.ln_StopPointBaseView.PavilionCount,
	dbo.ln_StopPointBaseView.DataSource,
	dbo.ln_StopPointBaseView.ModifiedDate,
	dbo.ln_StopPointBaseView.RowColor,
	dbo.ln_StopPoint.CrossroadDistance,
	dbo.ln_StopPoint.CheckDate,
	dbo.ln_GetStopPointLineRoutesCount(dbo.ln_StopPoint.ID) AS LineRouteCount,
	dbo.ln_GetStopSignCount(dbo.ln_StopPoint.ID) AS SignCount,
	dbo.ln_GetStopPointNamesCount(dbo.ln_StopPoint.ID) AS NameCount,
	dbo.ln_StopPoint.MeasureDate,
	dbo.ln_StopPoint.[WorkLoad],
	dbo.ln_StopPoint.Board,
	dbo.ln_StopPoint.Alight,
	dbo.rms_Status.Name AS CheckStatus
FROM
	dbo.ln_StopPoint
INNER JOIN
	dbo.ln_StopPointBaseView
ON
	dbo.ln_StopPointBaseView.ID = dbo.ln_StopPoint.ID
LEFT OUTER JOIN
	dbo.rms_Status
ON
	dbo.ln_StopPoint.CheckStatusID = dbo.rms_Status.ID
</Definition>
    </ViewMould>
