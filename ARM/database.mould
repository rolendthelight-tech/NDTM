CREATE VIEW
	[dbo].[geo_RoadView]
AS
SELECT
	geo_Road.ID,
	geo_RoadType.ShortName AS RoadType,
	geo_Road.Name,
	geo_Road.FullName,
	geo_Locality.Name AS Locality,
	geo_District.Name AS District,
	geo_Road.Category,
	geo_Road.Description
FROM
	geo_Road
LEFT OUTER JOIN geo_RoadType
	ON geo_Road.RoadTypeID = geo_RoadType.ID
LEFT OUTER JOIN geo_Locality
	ON geo_Road.LocalityID = geo_Locality.ID
LEFT OUTER JOIN geo_District
	ON geo_Road.DistrictID = geo_District.ID
</Definition>
