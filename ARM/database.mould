CREATE VIEW [dbo].[tm_ZoneView]
AS
SELECT     dbo.tm_Zone.ID,
		   dbo.geo_District.Name AS District,
		   dbo.tm_Zone.Code,
		   dbo.tm_Zone.Name,
		   dbo.tm_Zone.Type,
			dbo.tm_Zone.Employees,
			dbo.tm_Zone.Population,
			dbo.tm_Zone.Pupils,
			dbo.tm_Zone.WorkPlaces,
			dbo.tm_Zone.WorkPlaceService,
			dbo.tm_Zone.Houses,
			dbo.tm_Zone.VisumNo
FROM        dbo.tm_Zone LEFT OUTER JOIN
            dbo.geo_District ON dbo.tm_Zone.DistrictID = dbo.geo_District.ID
</Definition>
