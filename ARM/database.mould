      <Definition>
CREATE VIEW [dbo].[rms_ReportView]
AS
SELECT
			r.ID,
			r.EntityID,
			r.RevisionID,
			f.Name,
			f.FileDataGuid,
			e.CreatedDate,
			e.ModifiedDate,
			s.Name AS DataSource
FROM
		rms_Report r
	INNER JOIN
    cor_FileEntry f ON r.ID = f.ID
  INNER JOIN
    cor_Entity e ON f.ID = e.ID
  LEFT JOIN
    cor_DataSource s ON s.ID = e.DataSourceID
</Definition>
    </ViewMould>
