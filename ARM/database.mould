CREATE VIEW [dbo].[ln_PlacePointView]
AS
SELECT
	ln_StopPoint.ID,
	map_GeoPoint.X,
	map_GeoPoint.Y
FROM
	ln_StopPoint
INNER JOIN
	map_Entity2GeoPoint
ON
	map_Entity2GeoPoint.EntityID = ln_StopPoint.ID
INNER JOIN
	map_Layer
ON
	map_Layer.ID = map_Entity2GeoPoint.LayerID
INNER JOIN
	map_GeoPoint
ON
	map_Entity2GeoPoint.GeoPointID = map_GeoPoint.ID
WHERE
	map_Layer.Alias = 'PlaceStopPoint'
AND
	map_Layer.TableName = 'ln_StopPoint'
</Definition>
